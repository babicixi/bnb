# Environment variables.
# Copy to `.env` and fill in for local dev or production. Lines starting
# with # are ignored.

# HTTP listener (Render/Fly set PORT automatically; override only locally).
PORT=3000

# Cookie session signing key. MUST be a long random string in production —
# the app refuses to start in production with the default value.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-32+-char-random-string

# Set to "production" on hosted environments. Enables secure cookies,
# trust-proxy for X-Forwarded-* headers, and silences the demo-credentials log.
NODE_ENV=development

# Persistent state lives here. On Render/Fly mount your persistent disk at a
# path (e.g. /data) and set DATA_DIR=/data — state.json and uploads/ will
# both live under it and survive deploys/restarts.
# DATA_DIR=/data

# Fine-grained overrides — usually not needed if DATA_DIR is set.
# STATE_FILE=/data/state.json
# UPLOADS_DIR=/data/uploads

# Postgres connection string for the deployment-target database. Used by
# whatever migration runner you wire up (psql, supabase CLI, drizzle, etc).
# The current scaffold uses an in-memory repository; switch the repo
# implementation to a SQL adapter against `migrations/` to use this.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Brand contact + social handles. Each is optional — the landing page renders
# the matching card only if its value is set, and the booking proof page
# only shows the bank-transfer details if BRAND_BANK_NAME + BRAND_BANK_ACCOUNT_NUMBER
# are both present.
# BRAND_FB_URL=https://www.facebook.com/your.page
# BRAND_FB_HANDLE=your.page
# BRAND_IG_URL=https://www.instagram.com/yourhandle
# BRAND_IG_HANDLE=@yourhandle
# BRAND_TT_URL=https://www.tiktok.com/@yourhandle
# BRAND_TT_HANDLE=@yourhandle
# BRAND_PHONE_RESERVATIONS=09xx.xxx.xxx
# BRAND_PHONE_CS=09xx.xxx.xxx
# BRAND_BANK_NAME=
# BRAND_BANK_ACCOUNT_NUMBER=
# BRAND_BANK_ACCOUNT_HOLDER=

# Future placeholders — not yet wired:
# EMAIL_PROVIDER_API_KEY=
# SMS_PROVIDER_API_KEY=
# ZALO_API_KEY=
# WHATSAPP_API_KEY=
# TELEGRAM_BOT_TOKEN=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
# S3_REGION=
