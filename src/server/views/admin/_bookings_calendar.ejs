<div class="calendar">
  <div class="calendar-header">
    <a class="btn secondary" href="?<%= calendar.prevQuery %>">‹ Prev</a>
    <h2><%= calendar.label %></h2>
    <a class="btn secondary" href="?<%= calendar.nextQuery %>">Next ›</a>
  </div>
  <div class="calendar-grid" style="grid-template-columns: 160px repeat(<%= calendar.days.length %>, minmax(34px, 1fr));">
    <div class="col-head">Room</div>
    <% calendar.days.forEach(function(d){ %>
      <div class="col-head <%= d.isWeekend ? 'weekend' : '' %>" title="<%= d.label %>">
        <%= d.day %><br><span style="font-weight:400; color:#999;"><%= d.dow %></span>
      </div>
    <% }) %>

    <% rooms.forEach(function(r){ %>
      <div class="row-head"><%= r.name %><br><span class="muted-small">Room <%= r.roomNumber || '—' %></span></div>
      <% calendar.days.forEach(function(d){
           var dayBookings = (calendar.byRoomDay[r.id] && calendar.byRoomDay[r.id][d.iso]) || [];
           var maintenance = (calendar.maintenanceByRoomDay[r.id] && calendar.maintenanceByRoomDay[r.id][d.iso]) || [];
      %>
        <div class="day-cell <%= d.isWeekend ? 'weekend' : '' %>">
          <% maintenance.forEach(function(m){ %>
            <div class="m" title="Maintenance: <%= m.reason %><%= m.notes ? ' — ' + m.notes : '' %>">⚙ <%= m.reason %></div>
          <% }) %>
          <% dayBookings.forEach(function(item){ %>
            <a class="b <%= item.booking.status %>"
               href="/admin/bookings/<%= item.booking.id %>"
               title="<%= item.booking.bookingNumber %> · <%= item.guestName %> · <%= formatDateTime(item.booking.checkInAt) %> → <%= formatDateTime(item.booking.checkOutAt) %> · <%= item.booking.status %>">
              <%= item.guestName %>
            </a>
          <% }) %>
        </div>
      <% }) %>
    <% }) %>
  </div>
  <div class="calendar-legend">
    <span class="swatch" style="background:#2a7a3a"></span>confirmed
    <span class="swatch" style="background:#b58700"></span>pending payment
    <span class="swatch" style="background:#1f5fa3"></span>checked-in
    <span class="swatch" style="background:#a06226"></span>cleaning
    <span class="swatch" style="background:#b03030"></span>action required
    <span class="swatch" style="background:repeating-linear-gradient(135deg,#ddd 0,#ddd 4px,#eee 4px,#eee 8px);"></span>maintenance
  </div>
</div>
