<%
  function hhmmVN(d) {
    if (!d) return '';
    var s = new Date(d.getTime() + 7 * 60 * 60_000).toISOString();
    return s.slice(11, 16);
  }
  var dayCount = calendar.days.length; // 7
%>
<div class="calendar week">
  <div class="calendar-header">
    <a class="btn secondary" href="?<%= calendar.prevQuery %>">‹ Prev week</a>
    <h2><%= calendar.label %></h2>
    <span>
      <a class="btn secondary" href="?<%= calendar.todayQuery %>">This week</a>
      <a class="btn secondary" href="?<%= calendar.nextQuery %>">Next week ›</a>
    </span>
  </div>

  <div class="cal-room-row cal-header-row">
    <div class="row-head">Room</div>
    <div class="cal-day-track">
      <% calendar.days.forEach(function(d){ %>
        <div class="day-cell head <%= d.isWeekend ? 'weekend' : '' %> <%= d.isToday ? 'today' : '' %>">
          <span class="dow"><%= d.dow %></span>
          <strong class="dnum"><%= d.day %></strong>
          <span class="dmonth"><%= d.month %></span>
        </div>
      <% }) %>
    </div>
  </div>

  <% rooms.forEach(function(r){
       var bars = calendar.barsByRoom[r.id] || [];
       var maintBars = calendar.maintBarsByRoom[r.id] || [];
  %>
    <div class="cal-room-row">
      <div class="row-head"><%= r.name %><br><span class="muted-small">Room <%= r.roomNumber || '—' %></span></div>
      <div class="cal-day-track">
        <% calendar.days.forEach(function(d){ %>
          <div class="day-cell <%= d.isWeekend ? 'weekend' : '' %> <%= d.isToday ? 'today' : '' %>"></div>
        <% }) %>

        <%
          // Position every bar precisely by Vietnam-local clock:
          //   left   = (colStart - 1) + startHour/24       (days from week start)
          //   width  = (colSpan - 1) + (endHour - startHour)/24
          // This works for partial-day, day, and multi-day uniformly:
          //   • hourly 10:00-12:00 → starts at .417 of its cell, width .083 cells
          //   • day 15:00→11:00 next day → starts at .625 of day 1, ends at .458 of day 2
          //   • multi-day → starts at check-in hour, ends at check-out hour two cells later
          function barPos(bar) {
            var leftDays = (bar.colStart - 1) + bar.startHour / 24;
            var widthDays =
              (bar.colSpan - 1) + (bar.endHour - bar.startHour) / 24;
            return {
              left: (leftDays / dayCount) * 100,
              width: (widthDays / dayCount) * 100,
            };
          }
        %>
        <% maintBars.forEach(function(mb){
             var pos = barPos(mb);
        %>
          <div class="cal-bar maintenance <%= mb.isPartialDay ? 'partial' : '' %>"
               style="left: calc(<%= pos.left %>% + 2px); width: calc(<%= pos.width %>% - 4px);"
               title="Maintenance: <%= mb.block.reason %><%= mb.block.notes ? ' — ' + mb.block.notes : '' %>">
            ⚙ <%= mb.block.reason %>
          </div>
        <% }) %>
        <% bars.forEach(function(bar){
             var b = bar.booking;
             var isHourly = b.bookingType === 'hourly';
             var pos = barPos(bar);
        %>
          <a class="cal-bar <%= b.status %> <%= bar.isPartialDay ? 'partial' : '' %>"
             href="/admin/bookings/<%= b.id %>"
             style="left: calc(<%= pos.left %>% + 2px); width: calc(<%= pos.width %>% - 4px);"
             title="<%= b.bookingNumber %> · <%= bar.guestName %> · <%= formatDateTime(b.checkInAt) %> → <%= formatDateTime(b.checkOutAt) %> · <%= b.status %>">
            <% if (isHourly) { %><strong><%= hhmmVN(b.checkInAt) %>–<%= hhmmVN(b.checkOutAt) %></strong> · <% } %><%= bar.guestName %>
          </a>
        <% }) %>
      </div>
    </div>
  <% }) %>

  <div class="calendar-legend">
    <span class="swatch" style="background:#2a7a3a"></span>confirmed
    <span class="swatch" style="background:#b58700"></span>pending payment
    <span class="swatch" style="background:#1f5fa3"></span>checked-in
    <span class="swatch" style="background:#a06226"></span>cleaning
    <span class="swatch" style="background:#b03030"></span>action required
    <span class="swatch maintenance-swatch"></span>maintenance
  </div>
</div>
