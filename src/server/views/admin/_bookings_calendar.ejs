<div class="calendar">
  <div class="calendar-header">
    <a class="btn secondary" href="?<%= calendar.prevQuery %>">‹ Prev</a>
    <h2><%= calendar.label %></h2>
    <a class="btn secondary" href="?<%= calendar.nextQuery %>">Next ›</a>
  </div>

  <%
    const dayCount = calendar.days.length;
    const colTemplate = '160px repeat(' + dayCount + ', minmax(34px, 1fr))';
  %>

  <div class="cal-day-strip" style="display:grid; grid-template-columns: <%= colTemplate %>;">
    <div class="col-head">Room</div>
    <% calendar.days.forEach(function(d){ %>
      <div class="col-head <%= d.isWeekend ? 'weekend' : '' %>" title="<%= d.label %>">
        <%= d.day %><br><span style="font-weight:400; color:#999;"><%= d.dow %></span>
      </div>
    <% }) %>
  </div>

  <% rooms.forEach(function(r){
       var bars = calendar.barsByRoom[r.id] || [];
       var maintBars = calendar.maintBarsByRoom[r.id] || [];
  %>
    <div class="cal-room-row" style="display:grid; grid-template-columns: <%= colTemplate %>; position: relative;">
      <div class="row-head"><%= r.name %><br><span class="muted-small">Room <%= r.roomNumber || '—' %></span></div>
      <% calendar.days.forEach(function(d){ %>
        <div class="day-cell <%= d.isWeekend ? 'weekend' : '' %>"></div>
      <% }) %>

      <% maintBars.forEach(function(mb){ %>
        <div class="cal-bar maintenance"
             style="grid-row: 1; grid-column: <%= mb.colStart + 1 %> / span <%= mb.colSpan %>;"
             title="Maintenance: <%= mb.block.reason %><%= mb.block.notes ? ' — ' + mb.block.notes : '' %>">
          ⚙ <%= mb.block.reason %>
        </div>
      <% }) %>
      <% bars.forEach(function(bar){ %>
        <a class="cal-bar <%= bar.booking.status %>"
           href="/admin/bookings/<%= bar.booking.id %>"
           style="grid-row: 1; grid-column: <%= bar.colStart + 1 %> / span <%= bar.colSpan %>;"
           title="<%= bar.booking.bookingNumber %> · <%= bar.guestName %> · <%= formatDateTime(bar.booking.checkInAt) %> → <%= formatDateTime(bar.booking.checkOutAt) %> · <%= bar.booking.status %>">
          <%= bar.guestName %><span class="muted-small" style="opacity:0.85;"> · <%= bar.booking.bookingNumber %></span>
        </a>
      <% }) %>
    </div>
  <% }) %>

  <div class="calendar-legend">
    <span class="swatch" style="background:#2a7a3a"></span>confirmed
    <span class="swatch" style="background:#b58700"></span>pending payment
    <span class="swatch" style="background:#1f5fa3"></span>checked-in
    <span class="swatch" style="background:#a06226"></span>cleaning
    <span class="swatch" style="background:#b03030"></span>action required
    <span class="swatch maintenance-swatch"></span>maintenance
  </div>
</div>
