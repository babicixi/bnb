<%- include('../_header') %>
<%- include('_nav') %>
<h1>Pricing overrides</h1>
<p class="muted-small">
  Day-to-day pricing follows each room's defaults
  (weekday / weekend / per-hour / hourly tiers — set on the
  <a href="/admin/properties">Properties</a> page).
  This page is for <strong>overrides only</strong> — holidays, peak nights,
  and any one-off date you want to charge differently.
  All inputs are in <strong>thousands of VND</strong>; type <code>1500</code>
  for 1,500,000 ₫.
</p>
<% if (flash) { %><p class="success">Saved (<%= flash %>).</p><% } %>

<form method="get" action="/admin/pricing" class="card">
  <label>Room</label>
  <select name="roomId" onchange="this.form.submit()">
    <% rooms.forEach(function(r){ %>
      <option value="<%= r.id %>" <%= room && room.id === r.id ? 'selected' : '' %>><%= r.name %></option>
    <% }) %>
  </select>
  <% if (room) { %>
    <p class="muted-small" style="margin-top:0.5rem;">
      Defaults for <strong><%= room.name %></strong>:
      weekday <%= formatVnd(room.baseDayRateVnd) %>
      · weekend <%= room.baseWeekendRateVnd != null ? formatVnd(room.baseWeekendRateVnd) : '(uses weekday)' %>
      · per-hour fallback <%= formatVnd(room.baseHourlyRateVnd) %>/hr
      · hourly bookings <strong><%= room.hourlyEnabled === false ? 'DISABLED' : 'enabled' %></strong>.
    </p>
  <% } %>
</form>

<% if (room) { %>
<div class="card">
  <h2>Bulk percentage adjustment</h2>
  <p class="muted-small">Apply a flat <strong>+/-%</strong> against each selected room's defaults across a date range. Use a positive number to mark up (e.g. <code>15</code> for +15% on Tet), a negative number for a discount (e.g. <code>-10</code>). Re-runs replace any existing overrides on those dates.</p>
  <form method="post" action="/admin/pricing/bulk-percent">
    <input type="hidden" name="contextRoomId" value="<%= room.id %>" />
    <div class="grid cols-3">
      <div><label>From date</label><input type="date" name="fromDate" required /></div>
      <div><label>To date</label><input type="date" name="toDate" required /></div>
      <div><label>Percent (signed, e.g. 15 or -10)</label><input type="number" name="percent" step="1" required placeholder="15" /></div>
    </div>
    <h4 style="margin: 1rem 0 0.25rem;">Apply to which rooms</h4>
    <% buildings.forEach(function(b){
         var bRooms = rooms.filter(function(rr){ return rr.buildingId === b.id; });
         if (bRooms.length === 0) return;
    %>
      <p style="margin: 0.5rem 0 0.25rem;">
        <strong><%= b.name %></strong>
        <label class="muted-small" style="margin-left:0.5rem;">
          <input type="checkbox" onchange="var c=this.checked; this.form.querySelectorAll('input[name=&quot;roomIds&quot;][data-building=&quot;<%= b.id %>&quot;]').forEach(function(cb){cb.checked=c;});" /> all in building
        </label>
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:0.4rem 1rem;">
        <% bRooms.forEach(function(rr){ %>
          <label>
            <input type="checkbox" name="roomIds" value="<%= rr.id %>" data-building="<%= b.id %>" <%= rr.id === room.id ? 'checked' : '' %> />
            <%= rr.name %><% if (rr.roomNumber) { %> <span class="muted-small">· <%= rr.roomNumber %></span><% } %>
          </label>
        <% }) %>
      </div>
    <% }) %>
    <p style="margin-top:0.75rem;">
      <label><input type="checkbox" name="markSpecial" value="1" /> Mark every date as a <strong>special day</strong></label>
    </p>
    <label>Note (e.g. "Tet +15%", optional)</label>
    <input type="text" name="note" />
    <p><button type="submit">Apply percentage</button></p>
  </form>
</div>

<div class="card">
  <h2>Add a special-pricing date / range</h2>
  <p class="muted-small">Apply across a date range. Mon–Fri inside the range get the weekday rate; Sat/Sun get the weekend rate (or weekday if blank). Leave any row blank to keep the room's default for that piece. Tier prices are flat package rates — they override the room defaults only for the dates in this range.</p>
  <form method="post" action="/admin/pricing/bulk">
    <input type="hidden" name="roomId" value="<%= room.id %>" />
    <div class="grid cols-2">
      <div><label>From date</label><input type="date" name="fromDate" required /></div>
      <div><label>To date</label><input type="date" name="toDate" required /></div>
      <div><label>Weekday rate (₫'000)</label><input type="number" name="weekdayRateK" min="0" step="25" placeholder="leave blank to keep default" /></div>
      <div><label>Weekend rate (₫'000)</label><input type="number" name="weekendRateK" min="0" step="25" placeholder="leave blank to keep default" /></div>
      <div><label>Per-hour fallback (₫'000)</label><input type="number" name="hourlyRateK" min="0" step="25" placeholder="leave blank to keep default" /></div>
    </div>
    <h4 style="margin: 1rem 0 0.25rem;">Hourly tier prices (₫'000)</h4>
    <div class="grid cols-3">
      <div><label>2 h</label><input type="number" name="rate2hK" min="0" step="25" /></div>
      <div><label>4 h</label><input type="number" name="rate4hK" min="0" step="25" /></div>
      <div><label>6 h</label><input type="number" name="rate6hK" min="0" step="25" /></div>
      <div><label>8 h</label><input type="number" name="rate8hK" min="0" step="25" /></div>
      <div><label>12 h</label><input type="number" name="rate12hK" min="0" step="25" /></div>
    </div>
    <p>
      <label><input type="checkbox" name="markSpecial" value="1" checked /> Mark every date in this range as a <strong>special day</strong> (e.g. holiday)</label>
    </p>
    <label>Note (e.g. "Tet holiday", optional)</label>
    <input type="text" name="note" />
    <p><button type="submit">Save override(s)</button></p>
  </form>
</div>

<div class="card">
  <h2>Active overrides for <%= room.name %></h2>
  <% if (rates.length === 0) { %>
    <p class="muted">No overrides — every future date uses the room's default rates. Add holidays / special pricing above when needed.</p>
  <% } else { %>
    <form id="bulk-overrides-form" method="post" action="/admin/pricing/bulk-remove" style="display:none" onsubmit="return confirm('Remove all selected overrides? Cannot be undone.')">
      <input type="hidden" name="roomId" value="<%= room.id %>" />
    </form>
    <table>
      <thead>
        <tr>
          <th><input type="checkbox" onchange="var c=this.checked; document.querySelectorAll('input.override-row-cb').forEach(function(cb){cb.checked=c;});" title="Select all" /></th>
          <th>Date</th>
          <th>Day</th>
          <th>Day rate</th>
          <th>Per-hour</th>
          <th>Tiers</th>
          <th>Note</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% rates.forEach(function(r){
             var dow = new Date(r.rateDate + 'T00:00:00Z').getUTCDay();
             var dowLabel = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][dow];
             var weekend = dow === 0 || dow === 6;
             var t = r.hourlyTiers || {};
             function tierText(){
               var parts = [];
               if (t.rate2hVnd != null) parts.push('2h ' + formatVnd(t.rate2hVnd));
               if (t.rate4hVnd != null) parts.push('4h ' + formatVnd(t.rate4hVnd));
               if (t.rate6hVnd != null) parts.push('6h ' + formatVnd(t.rate6hVnd));
               if (t.rate8hVnd != null) parts.push('8h ' + formatVnd(t.rate8hVnd));
               if (t.rate12hVnd != null) parts.push('12h ' + formatVnd(t.rate12hVnd));
               return parts.length ? parts.join(' · ') : '(uses room defaults)';
             }
        %>
          <tr class="<%= weekend ? 'weekend' : '' %> <%= r.isSpecial ? 'special' : '' %>">
            <td><input class="override-row-cb" form="bulk-overrides-form" type="checkbox" name="dates" value="<%= r.rateDate %>" /></td>
            <td>
              <strong><%= r.rateDate %></strong>
              <% if (r.isSpecial) { %><br><span class="badge bad">special</span><% } %>
            </td>
            <td><span class="muted-small"><%= dowLabel %></span></td>
            <td><%= formatVnd(r.dayRateVnd) %></td>
            <td><%= formatVnd(r.hourlyRateVnd) %>/hr</td>
            <td class="muted-small"><%= tierText() %></td>
            <td><%= r.note || '' %></td>
            <td>
              <details>
                <summary class="muted-small">Edit</summary>
                <form method="post" action="/admin/pricing/edit" style="margin-top:0.5rem;">
                  <input type="hidden" name="roomId" value="<%= room.id %>" />
                  <input type="hidden" name="rateDate" value="<%= r.rateDate %>" />
                  <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
                    <label class="muted-small">Day</label><input type="number" name="dayRateK" value="<%= r.dayRateVnd / 1000 %>" min="0" step="25" style="max-width:100px" />
                    <label class="muted-small">Hr</label><input type="number" name="hourlyRateK" value="<%= r.hourlyRateVnd / 1000 %>" min="0" step="25" style="max-width:100px" />
                    <label class="muted-small">2h</label><input type="number" name="rate2hK" value="<%= t.rate2hVnd != null ? t.rate2hVnd / 1000 : '' %>" min="0" step="25" style="max-width:80px" />
                    <label class="muted-small">4h</label><input type="number" name="rate4hK" value="<%= t.rate4hVnd != null ? t.rate4hVnd / 1000 : '' %>" min="0" step="25" style="max-width:80px" />
                    <label class="muted-small">6h</label><input type="number" name="rate6hK" value="<%= t.rate6hVnd != null ? t.rate6hVnd / 1000 : '' %>" min="0" step="25" style="max-width:80px" />
                    <label class="muted-small">8h</label><input type="number" name="rate8hK" value="<%= t.rate8hVnd != null ? t.rate8hVnd / 1000 : '' %>" min="0" step="25" style="max-width:80px" />
                    <label class="muted-small">12h</label><input type="number" name="rate12hK" value="<%= t.rate12hVnd != null ? t.rate12hVnd / 1000 : '' %>" min="0" step="25" style="max-width:80px" />
                  </div>
                  <p>
                    <label><input type="checkbox" name="isSpecial" value="1" <%= r.isSpecial ? 'checked' : '' %> /> Special day</label>
                    <label class="muted-small">Note</label>
                    <input type="text" name="note" value="<%= r.note || '' %>" style="max-width:240px" />
                  </p>
                  <p>
                    <button type="submit" class="secondary">Save</button>
                  </p>
                </form>
              </details>
              <form method="post" action="/admin/pricing/remove" style="display:inline" onsubmit="return confirm('Remove the override for <%= r.rateDate %>?')">
                <input type="hidden" name="roomId" value="<%= room.id %>" />
                <input type="hidden" name="rateDate" value="<%= r.rateDate %>" />
                <button type="submit" class="danger">Remove</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <p style="margin-top:0.75rem; display:flex; gap:0.5rem; flex-wrap:wrap;">
      <button type="submit" form="bulk-overrides-form" class="danger">Remove selected</button>
      <form method="post" action="/admin/pricing/clear-all" style="display:inline" onsubmit="return confirm('Clear ALL overrides for <%= room.name %>? Pricing will fall back to room defaults for every date.')">
        <input type="hidden" name="roomId" value="<%= room.id %>" />
        <button type="submit" class="danger">Clear all overrides</button>
      </form>
    </p>
  <% } %>
</div>

<div class="card">
  <h2>Copy from another room</h2>
  <p class="muted-small">Replaces this room's overrides with a copy of the source room's overrides.</p>
  <form method="post" action="/admin/pricing/copy">
    <input type="hidden" name="toRoomId" value="<%= room.id %>" />
    <label>Copy overrides from</label>
    <select name="fromRoomId">
      <% rooms.forEach(function(r){ if (r.id !== room.id) { %>
        <option value="<%= r.id %>"><%= r.name %></option>
      <% } }) %>
    </select>
    <p><button type="submit" class="secondary">Copy &amp; replace</button></p>
  </form>
</div>
<% } %>
<%- include('../_footer') %>
