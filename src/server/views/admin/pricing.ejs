<%- include('../_header') %>
<%- include('_nav') %>
<h1>Pricing</h1>
<p class="muted-small">All rates entered in <strong>thousands of VND</strong>. Type <code>900</code> for 900,000 ₫.</p>
<% if (flash) { %><p class="success">Saved (<%= flash %>).</p><% } %>

<form method="get" action="/admin/pricing" class="card">
  <label>Room</label>
  <select name="roomId" onchange="this.form.submit()">
    <% rooms.forEach(function(r){ %>
      <option value="<%= r.id %>" <%= room && room.id === r.id ? 'selected' : '' %>><%= r.name %></option>
    <% }) %>
  </select>
  <% if (room) { %>
    <p class="muted-small">
      Defaults: weekday <%= formatVnd(room.baseDayRateVnd) %>
      · weekend <%= room.baseWeekendRateVnd != null ? formatVnd(room.baseWeekendRateVnd) : '(uses weekday)' %>
      · hourly fallback <%= formatVnd(room.baseHourlyRateVnd) %>/hr
      · hourly bookings <strong><%= room.hourlyEnabled === false ? 'DISABLED' : 'enabled' %></strong>.
      Edit on the <a href="/admin/properties">Properties</a> page.
    </p>
  <% } %>
</form>

<% if (room) { %>
<div class="card">
  <h2>Bulk edit (<%= room.name %>)</h2>
  <p class="muted-small">Apply rates across a date range. Weekday rate goes to Mon–Fri; weekend rate to Sat/Sun (if blank, weekday rate is used). Tier prices are flat package rates for short stays. Leave any field blank to keep that field's existing value on each day.</p>
  <form method="post" action="/admin/pricing/bulk">
    <input type="hidden" name="roomId" value="<%= room.id %>" />
    <div class="grid cols-2">
      <div><label>From date</label><input type="date" name="fromDate" required /></div>
      <div><label>To date</label><input type="date" name="toDate" required /></div>
      <div><label>Weekday rate (₫'000)</label><input type="number" name="weekdayRateK" min="0" step="0.5" placeholder="e.g. 900" /></div>
      <div><label>Weekend rate (₫'000)</label><input type="number" name="weekendRateK" min="0" step="0.5" placeholder="e.g. 1200" /></div>
      <div><label>Per-hour fallback (₫'000)</label><input type="number" name="hourlyRateK" min="0" step="0.5" placeholder="e.g. 150" /></div>
    </div>
    <h4 style="margin: 1rem 0 0.25rem;">Hourly tier prices (₫'000)</h4>
    <div class="grid cols-3">
      <div><label>2 h</label><input type="number" name="rate2hK" min="0" step="0.5" /></div>
      <div><label>4 h</label><input type="number" name="rate4hK" min="0" step="0.5" /></div>
      <div><label>6 h</label><input type="number" name="rate6hK" min="0" step="0.5" /></div>
      <div><label>8 h</label><input type="number" name="rate8hK" min="0" step="0.5" /></div>
      <div><label>12 h</label><input type="number" name="rate12hK" min="0" step="0.5" /></div>
    </div>
    <p>
      <label><input type="checkbox" name="markSpecial" value="1" /> Mark every date in this range as a <strong>special day</strong> (e.g. holiday)</label>
    </p>
    <label>Note (e.g. "Tet holiday", optional)</label>
    <input type="text" name="note" />
    <p><button type="submit">Apply bulk</button></p>
  </form>
</div>

<div class="card">
  <h2>Copy from another room</h2>
  <form method="post" action="/admin/pricing/copy">
    <input type="hidden" name="toRoomId" value="<%= room.id %>" />
    <label>Copy rates from</label>
    <select name="fromRoomId">
      <% rooms.forEach(function(r){ if (r.id !== room.id) { %>
        <option value="<%= r.id %>"><%= r.name %></option>
      <% } }) %>
    </select>
    <p><button type="submit" class="secondary">Copy &amp; replace</button></p>
  </form>
</div>

<div class="card">
  <h2>Daily rates (next 60 days)</h2>
  <p class="muted-small">Click <em>Edit tiers</em> on a row to override the per-tier hourly prices for that specific date or mark it as special. Otherwise the room's default tiers apply.</p>
  <table>
    <thead>
      <tr>
        <th>Date</th>
        <th>Day</th>
        <th>Day rate (₫'000)</th>
        <th>Per-hour (₫'000)</th>
        <th>Tiers / special</th>
        <th>Save</th>
      </tr>
    </thead>
    <tbody>
      <% rates.forEach(function(r){
           var dow = new Date(r.rateDate + 'T00:00:00Z').getUTCDay();
           var dowLabel = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'][dow];
           var weekend = dow === 0 || dow === 6;
           var t = r.hourlyTiers || {};
      %>
        <tr class="<%= weekend ? 'weekend' : '' %> <%= r.isSpecial ? 'special' : '' %>">
          <td>
            <strong><%= r.rateDate %></strong>
            <% if (r.isSpecial) { %><br><span class="badge bad">special</span><% } %>
            <% if (r.note) { %><br><span class="muted-small"><%= r.note %></span><% } %>
          </td>
          <td><span class="muted-small <%= weekend ? '' : '' %>"><%= dowLabel %></span></td>
          <td>
            <form method="post" action="/admin/pricing/edit" id="rate-<%= r.rateDate %>" style="display:none"></form>
            <input form="rate-<%= r.rateDate %>" type="hidden" name="roomId" value="<%= room.id %>" />
            <input form="rate-<%= r.rateDate %>" type="hidden" name="rateDate" value="<%= r.rateDate %>" />
            <input form="rate-<%= r.rateDate %>" type="number" name="dayRateK" value="<%= r.dayRateVnd / 1000 %>" min="0" step="0.5" style="max-width:110px" />
            <span class="muted-small"><%= formatVnd(r.dayRateVnd) %></span>
          </td>
          <td>
            <input form="rate-<%= r.rateDate %>" type="number" name="hourlyRateK" value="<%= r.hourlyRateVnd / 1000 %>" min="0" step="0.5" style="max-width:110px" />
          </td>
          <td>
            <details>
              <summary><span class="muted-small">
                <% if (t.rate2hVnd != null || t.rate4hVnd != null || t.rate6hVnd != null || t.rate8hVnd != null || t.rate12hVnd != null) { %>
                  Custom tiers
                <% } else { %>
                  Edit tiers / special
                <% } %>
              </span></summary>
              <div style="display:flex; flex-wrap:wrap; gap:0.4rem; align-items:center; margin-top:0.4rem;">
                <span class="muted-small">2h</span><input form="rate-<%= r.rateDate %>" type="number" name="rate2hK" value="<%= t.rate2hVnd != null ? t.rate2hVnd / 1000 : '' %>" min="0" step="0.5" style="max-width:80px" />
                <span class="muted-small">4h</span><input form="rate-<%= r.rateDate %>" type="number" name="rate4hK" value="<%= t.rate4hVnd != null ? t.rate4hVnd / 1000 : '' %>" min="0" step="0.5" style="max-width:80px" />
                <span class="muted-small">6h</span><input form="rate-<%= r.rateDate %>" type="number" name="rate6hK" value="<%= t.rate6hVnd != null ? t.rate6hVnd / 1000 : '' %>" min="0" step="0.5" style="max-width:80px" />
                <span class="muted-small">8h</span><input form="rate-<%= r.rateDate %>" type="number" name="rate8hK" value="<%= t.rate8hVnd != null ? t.rate8hVnd / 1000 : '' %>" min="0" step="0.5" style="max-width:80px" />
                <span class="muted-small">12h</span><input form="rate-<%= r.rateDate %>" type="number" name="rate12hK" value="<%= t.rate12hVnd != null ? t.rate12hVnd / 1000 : '' %>" min="0" step="0.5" style="max-width:80px" />
              </div>
              <div style="margin-top:0.4rem;">
                <label><input form="rate-<%= r.rateDate %>" type="checkbox" name="isSpecial" value="1" <%= r.isSpecial ? 'checked' : '' %> /> Special day</label>
              </div>
              <div>
                <label class="muted-small">Note</label>
                <input form="rate-<%= r.rateDate %>" type="text" name="note" value="<%= r.note || '' %>" placeholder="e.g. Tet holiday" />
              </div>
            </details>
          </td>
          <td><button form="rate-<%= r.rateDate %>" type="submit" class="secondary">Save</button></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<% } %>
<%- include('../_footer') %>
