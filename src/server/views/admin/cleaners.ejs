<%- include('../_header') %>
<%- include('_nav') %>
<h1>Cleaning crew</h1>
<p class="muted-small">
  Earnings are tracked <strong>per completed job</strong> at each cleaner's fixed
  rate. Pay-rate values are entered in <strong>thousands of VND</strong>
  (type <code>120</code> for ₫120,000 per job).
</p>

<form method="get" action="/admin/cleaners" class="card" style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items:flex-end;">
  <div style="flex:0 0 auto;">
    <label>From week</label>
    <input type="date" name="from" value="<%= filters.from %>" />
  </div>
  <div style="flex:0 0 auto;">
    <label>To week</label>
    <input type="date" name="to" value="<%= filters.to %>" />
  </div>
  <div style="flex:0 0 auto;">
    <button type="submit">Apply range</button>
    <% if (filters.from || filters.to) { %>
      <a href="/admin/cleaners" class="btn secondary" style="margin-left:0.4rem;">Clear</a>
    <% } %>
  </div>
  <div class="muted-small" style="flex:1 1 100%;">
    Filters every weekly table on this page (top dashboard + each cleaner's history).
  </div>
</form>

<div class="card">
  <h2>Weekly payroll summary — all cleaners</h2>
  <% if (aggregateRows.length === 0) { %>
    <p class="muted">No cleaning activity yet.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Week of</th>
          <th>Completed jobs</th>
          <th>Earned</th>
          <th>Paid</th>
          <th>Outstanding</th>
        </tr>
      </thead>
      <tbody>
        <% aggregateRows.forEach(function(r){
             var outstanding = Math.max(0, r.earnedVnd - r.paidAmountVnd);
        %>
          <tr>
            <td><strong><%= r.weekStartIso %></strong></td>
            <td><%= r.jobsCompleted %></td>
            <td><%= formatVnd(r.earnedVnd) %></td>
            <td><%= formatVnd(r.paidAmountVnd) %></td>
            <td>
              <% if (outstanding > 0) { %>
                <span class="badge bad"><%= formatVnd(outstanding) %></span>
              <% } else if (r.earnedVnd > 0) { %>
                <span class="badge good">paid</span>
              <% } else { %>
                —
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<% cleanerRows.forEach(function(row){ %>
  <div class="card">
    <h2>
      <%= row.cleaner.fullName %>
      <span class="badge <%= row.cleaner.isActive ? 'good' : 'bad' %>"><%= row.cleaner.isActive ? 'active' : 'inactive' %></span>
      <a href="/admin/cleaners/<%= row.cleaner.id %>/report.csv" class="btn secondary" style="margin-left:0.5rem; font-size:0.85rem;">Download CSV report</a>
    </h2>
    <p class="muted-small">
      <%= row.cleaner.email %><% if (row.cleaner.phone) { %> · <%= row.cleaner.phone %><% } %>
      · lifetime: <%= row.lifetimeJobs %> jobs · earned <%= formatVnd(row.lifetimeEarned) %> · paid <%= formatVnd(row.lifetimePaid) %>
    </p>

    <details style="margin-bottom: 0.75rem;">
      <summary><span class="badge">Edit profile</span></summary>
      <form method="post" action="/admin/cleaners/<%= row.cleaner.id %>/edit">
        <div class="grid cols-2">
          <div><label>Full name</label><input name="fullName" value="<%= row.cleaner.fullName %>" required /></div>
          <div><label>Email</label><input type="email" name="email" value="<%= row.cleaner.email %>" required /></div>
          <div><label>Phone</label><input name="phone" value="<%= row.cleaner.phone || '' %>" /></div>
          <div><label>New password (leave blank to keep current)</label><input type="text" name="password" autocomplete="new-password" /></div>
        </div>
        <p><button type="submit">Save profile</button></p>
      </form>
    </details>

    <div class="grid cols-2">
      <div>
        <h3>Pay rate</h3>
        <p>Fixed pay per job: <strong><%= row.profile ? formatVnd(row.profile.fixedPayPerJobVnd) : '—' %></strong></p>
        <form method="post" action="/admin/cleaners/<%= row.cleaner.id %>/pay">
          <label>New rate (₫'000 per job)</label>
          <input type="number" name="fixedPayPerJobK" step="1" min="0" value="<%= row.profile ? row.profile.fixedPayPerJobVnd / 1000 : 0 %>" required style="max-width:160px" />
          <button type="submit" class="secondary">Save rate</button>
        </form>
        <p>
          <form method="post" action="/admin/cleaners/<%= row.cleaner.id %>/toggle" style="display:inline">
            <button type="submit" class="secondary"><%= row.cleaner.isActive ? 'Deactivate' : 'Activate' %> cleaner</button>
          </form>
          <form method="post" action="/admin/cleaners/<%= row.cleaner.id %>/delete" onsubmit="return confirm('Permanently delete this cleaner? Only allowed if they have no jobs or payments.')" style="display:inline; margin-left:0.5rem;">
            <button type="submit" class="danger">Permanently delete</button>
          </form>
        </p>
      </div>

      <div>
        <h3>Upcoming + recent jobs (next 8)</h3>
        <% if (row.upcomingJobs.length === 0) { %><p class="muted-small">No upcoming or recent jobs.</p><% } %>
        <% row.upcomingJobs.forEach(function(j){
             var b = bookingForJob(j); var r = roomForJob(j);
        %>
          <details style="margin-bottom: 0.5rem;">
            <summary>
              <%= formatDateTime(j.windowStartAt) %> · <%= r ? r.name : '—' %> ·
              <span class="badge"><%= j.status %></span>
              <% if (b) { %> · <a href="/admin/bookings/<%= b.id %>"><%= b.bookingNumber %></a><% } %>
            </summary>
            <form method="post" action="/admin/cleaning-jobs/<%= j.id %>/edit">
              <div class="grid cols-2">
                <div>
                  <label>Assigned cleaner</label>
                  <select name="assignedToUserId">
                    <option value="">— unassigned —</option>
                    <% allCleaners.forEach(function(c){ %>
                      <option value="<%= c.id %>" <%= c.id === j.assignedToUserId ? 'selected' : '' %>><%= c.fullName %></option>
                    <% }) %>
                  </select>
                </div>
                <div>
                  <label>Status</label>
                  <select name="status">
                    <% ['assigned','arrived','in_progress','completed','cancelled'].forEach(function(s){ %>
                      <option value="<%= s %>" <%= s === j.status ? 'selected' : '' %>><%= s %></option>
                    <% }) %>
                  </select>
                </div>
                <div>
                  <label>Window start (Vietnam time)</label>
                  <input type="datetime-local" name="windowStartAt" value="<%= j.windowStartAt.toISOString().slice(0,16) %>" />
                </div>
                <div>
                  <label>Window end</label>
                  <input type="datetime-local" name="windowEndAt" value="<%= j.windowEndAt.toISOString().slice(0,16) %>" />
                </div>
              </div>
              <p><button type="submit" class="secondary">Save job</button></p>
            </form>
          </details>
        <% }) %>
      </div>
    </div>

    <h3>Weekly payroll <span class="muted-small">(every week with activity, including historical)</span></h3>
    <% if (row.weeklyRows.length === 0) { %>
      <p class="muted">No payroll activity yet.</p>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Week of</th>
              <th>Jobs completed</th>
              <th>Earned</th>
              <th>Paid</th>
              <th>Screenshots</th>
              <th>Upload payment</th>
            </tr>
          </thead>
          <tbody>
            <% row.weeklyRows.forEach(function(w){
                 var outstanding = Math.max(0, w.earnedVnd - w.paidAmountVnd);
                 var formId = 'pay-' + row.cleaner.id + '-' + w.weekStartIso;
            %>
              <tr>
                <td>
                  <strong><%= w.weekStartIso %></strong>
                  <% if (outstanding > 0) { %><br><span class="badge bad"><%= formatVnd(outstanding) %> due</span>
                  <% } else if (w.earnedVnd > 0) { %><br><span class="badge good">paid</span><% } %>
                </td>
                <td><%= w.jobsCompleted %></td>
                <td><%= formatVnd(w.earnedVnd) %></td>
                <td><%= formatVnd(w.paidAmountVnd) %></td>
                <td>
                  <% if (w.payments.length === 0) { %>
                    <span class="muted-small">—</span>
                  <% } else { %>
                    <% w.payments.forEach(function(p){
                         var isVoid = p.status === 'void';
                    %>
                      <div style="display:flex; align-items:center; gap:0.4rem; margin-bottom:0.2rem; <%= isVoid ? 'opacity:0.5;' : '' %>">
                        <% if (p.screenshotUrl) { %>
                          <a href="<%= p.screenshotUrl %>" target="_blank" title="<%= formatVnd(p.amountVnd) %> · <%= p.jobsCount %> jobs · <%= formatDateTime(p.paidAt) %><% if (p.notes) { %> · <%= p.notes %><% } %>">
                            <img src="<%= p.screenshotUrl %>" alt="proof" style="height:36px; vertical-align:middle; border:1px solid var(--border); border-radius:3px;" />
                          </a>
                        <% } else { %>
                          <span class="muted-small" title="<%= formatDateTime(p.paidAt) %>"><%= formatVnd(p.amountVnd) %></span>
                        <% } %>
                        <span class="badge <%= isVoid ? 'bad' : 'good' %>"><%= isVoid ? 'voided' : 'paid' %></span>
                        <form method="post" action="/admin/cleaner-payments/<%= p.id %>/toggle" style="display:inline">
                          <button type="submit" class="secondary" style="padding:0.15rem 0.5rem; font-size:0.78rem;"><%= isVoid ? 'Mark paid' : 'Mark unpaid' %></button>
                        </form>
                        <form method="post" action="/admin/cleaner-payments/<%= p.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this payment record? Cannot be undone.')">
                          <button type="submit" class="danger" style="padding:0.15rem 0.5rem; font-size:0.78rem;">×</button>
                        </form>
                      </div>
                    <% }) %>
                  <% } %>
                </td>
                <td>
                  <form method="post" action="/admin/cleaners/<%= row.cleaner.id %>/payments" enctype="multipart/form-data" id="<%= formId %>">
                    <input type="hidden" name="weekStartIso" value="<%= w.weekStartIso %>" />
                    <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
                      <label class="muted-small">Jobs</label>
                      <input type="number" name="jobsCount" min="0" value="<%= w.jobsCompleted %>" required style="max-width:70px" />
                      <label class="muted-small">₫'000</label>
                      <input type="number" name="amountK" min="0" step="1" value="<%= outstanding > 0 ? Math.round(outstanding / 1000) : '' %>" placeholder="amount" required style="max-width:90px" />
                      <input type="file" name="screenshot" accept="image/*" style="max-width:170px" />
                      <button type="submit" class="secondary">Upload</button>
                    </div>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
<% }) %>

<div class="card">
  <h2>Add a cleaner</h2>
  <form method="post" action="/admin/cleaners">
    <div class="grid cols-2">
      <div><label>Full name</label><input name="fullName" required /></div>
      <div><label>Email</label><input type="email" name="email" required /></div>
      <div><label>Phone (optional)</label><input name="phone" /></div>
      <div><label>Initial password (≥ 8 chars)</label><input type="text" name="password" required /></div>
      <div><label>Fixed pay per job (₫'000)</label><input type="number" name="fixedPayPerJobK" step="1" min="0" required /></div>
    </div>
    <p><button type="submit">Create cleaner</button></p>
  </form>
</div>
<%- include('../_footer') %>
