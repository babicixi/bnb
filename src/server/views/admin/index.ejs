<%- include('../_header') %>
<%- include('_nav') %>

<%
  function viewQuery(v) {
    var p = new URLSearchParams();
    Object.entries(filters).forEach(function(kv){
      if (kv[1] && kv[0] !== 'view' && kv[0] !== 'cal') p.set(kv[0], kv[1]);
    });
    p.set('view', v);
    return p.toString();
  }
%>
<h1 style="display:flex; align-items:center; gap:1rem; flex-wrap:wrap;">
  Bookings
  <span class="view-toggle">
    <a href="/admin?<%= viewQuery('week') %>" class="<%= view === 'week' ? 'active' : '' %>">Week</a>
    <a href="/admin?<%= viewQuery('month') %>" class="<%= view === 'month' ? 'active' : '' %>">Month</a>
    <a href="/admin?<%= viewQuery('table') %>" class="<%= view === 'table' ? 'active' : '' %>">Table</a>
  </span>
</h1>

<p style="margin: 0 0 1rem;">
  <a class="btn" href="/admin/today">Today's operations</a>
  <a class="btn secondary" href="/admin/refunds">Pending refunds</a>
  <a class="btn secondary" href="/admin/extras">Pending extras</a>
</p>

<form method="get" action="/admin" class="card">
  <input type="hidden" name="view" value="<%= view %>" />
  <div class="grid cols-3">
    <div>
      <label>From</label>
      <input type="date" name="from" value="<%= filters.from || '' %>" />
    </div>
    <div>
      <label>To</label>
      <input type="date" name="to" value="<%= filters.to || '' %>" />
    </div>
    <div>
      <label>Status</label>
      <select name="status">
        <option value="">Any</option>
        <% ['held','pending_payment','confirmed','checked_in','checked_out','cleaning_assigned','cleaning_in_progress','cleaned','extra_payment_required','refund_pending','cancellation_requested','cancelled','closed'].forEach(function(s){ %>
          <option value="<%= s %>" <%= filters.status === s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label>Payment status</label>
      <select name="paymentStatus">
        <option value="">Any</option>
        <% ['pending','proof_uploaded','proof_invalid','verified','refunded','cancelled'].forEach(function(s){ %>
          <option value="<%= s %>" <%= filters.paymentStatus === s ? 'selected' : '' %>><%= s %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label>Building</label>
      <select name="buildingId">
        <option value="">Any</option>
        <% buildings.forEach(function(b){ %>
          <option value="<%= b.id %>" <%= filters.buildingId === b.id ? 'selected' : '' %>><%= b.name %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label>Room</label>
      <select name="roomId">
        <option value="">Any</option>
        <% rooms.forEach(function(r){ %>
          <option value="<%= r.id %>" <%= filters.roomId === r.id ? 'selected' : '' %>><%= r.name %></option>
        <% }) %>
      </select>
    </div>
    <div>
      <label>Sales agent</label>
      <select name="agentId">
        <option value="">Any</option>
        <% agents.forEach(function(a){ %>
          <option value="<%= a.id %>" <%= filters.agentId === a.id ? 'selected' : '' %>><%= a.fullName %></option>
        <% }) %>
      </select>
    </div>
  </div>
  <p><button type="submit">Filter</button></p>
</form>

<% if (view === 'week') { %>
  <%- include('_bookings_calendar', { calendar, rooms: calendarRooms, formatVnd, formatDateTime }) %>
<% } else if (view === 'month') { %>
  <%- include('_bookings_month', { monthGrid, formatVnd, formatDateTime }) %>
<% } else { %>
  <table>
    <thead>
      <tr>
        <th>#</th><th>Room</th><th>Guest</th><th>Check-in</th><th>Check-out</th>
        <th>Agent</th><th>Cleaner</th><th>Status</th><th>Payment</th>
        <th>Minibar</th><th>Damages</th><th>Total</th><th></th>
      </tr>
    </thead>
    <tbody>
      <% if (bookings.length === 0) { %>
        <tr><td colspan="13" class="muted">No bookings match the filters yet.</td></tr>
      <% } %>
      <% bookings.forEach(function(b){
           var g = guestForBooking(b);
           var r = roomForBooking(b);
           var agent = b.salesAgentId ? users.get(b.salesAgentId) : null;
           var job = cleaningJobForBooking(b);
           var cleaner = job && job.assignedToUserId ? users.get(job.assignedToUserId) : null;
      %>
        <tr>
          <td><a href="/admin/bookings/<%= b.id %>"><%= b.bookingNumber %></a></td>
          <td><%= r ? r.name : '—' %></td>
          <td><%= g ? g.fullName : '—' %><% if (g && g.phone) { %><br><span class="muted-small"><%= g.phone %></span><% } %></td>
          <td><%= formatDateTime(b.checkInAt) %></td>
          <td><%= formatDateTime(b.checkOutAt) %></td>
          <td><%= agent ? agent.fullName : '—' %></td>
          <td><%= cleaner ? cleaner.fullName : '—' %></td>
          <td><span class="badge"><%= b.status %></span></td>
          <td><span class="badge"><%= b.paymentStatus %></span></td>
          <td><%= b.minibarChargesVnd ? formatVnd(b.minibarChargesVnd) : '—' %></td>
          <td><%= b.damageChargesVnd ? formatVnd(b.damageChargesVnd) : '—' %></td>
          <td><%= formatVnd(b.finalRoomChargeVnd + b.securityDepositVnd) %></td>
          <td><a href="/admin/bookings/<%= b.id %>" class="btn secondary">Open</a></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>
<%- include('../_footer') %>
