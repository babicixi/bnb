<%- include('../_header') %>
<%- include('_nav') %>
<h1>Guests <span class="muted-small">· CRM</span></h1>
<p class="muted-small">
  Every guest who has ever held, booked, or stayed appears here, sorted by most-recent stay.
  Use the export to seed marketing outreach (e.g. follow up with anyone who tried a particular
  minibar item).
</p>

<form method="get" action="/admin/guests" class="card" style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items:flex-end;">
  <div style="flex:1 1 320px;">
    <label>Search</label>
    <input type="text" name="q" value="<%= query %>" placeholder="name, email, phone, fb, ig, notes" />
  </div>
  <div style="flex:0 0 auto;">
    <button type="submit">Search</button>
    <% if (query) { %><a href="/admin/guests" class="btn secondary" style="margin-left:0.4rem;">Clear</a><% } %>
  </div>
  <div style="flex:0 0 auto;">
    <a href="/admin/guests/export.csv" class="btn">Download CRM CSV</a>
  </div>
</form>

<div class="card">
  <h2><%= rows.length %> guest<%= rows.length === 1 ? '' : 's' %><% if (query) { %> matching "<%= query %>"<% } %></h2>
  <% if (rows.length === 0) { %>
    <p class="muted">No guests match.</p>
  <% } else { %>
    <div class="table-wrap">
      <table class="bookings-table guests-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Facebook</th>
            <th>Instagram</th>
            <th>Bookings</th>
            <th>Total spent</th>
            <th>Last stay</th>
            <th>Favourite minibar</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach(function(r){
               var lastStay = r.lastStay ? r.lastStay.toISOString().slice(0,10) : '—';
               // top minibar items across all guest bookings
               var itemTally = new Map();
               r.bookings.forEach(function(b){
                 (r.minibarByBooking.get(b.id) || []).forEach(function(u){
                   itemTally.set(u.minibarItemId, (itemTally.get(u.minibarItemId) || 0) + u.quantity);
                 });
               });
               var topItems = Array.from(itemTally.entries())
                 .sort(function(a,b){ return b[1]-a[1]; })
                 .slice(0, 3)
                 .map(function(pair){
                   var item = minibarItemById(pair[0]);
                   return (item ? item.name : pair[0]) + ' ×' + pair[1];
                 })
                 .join(', ');
          %>
            <tr>
              <td class="cell-ellipsis" title="<%= r.guest.fullName %>">
                <strong><%= r.guest.fullName %></strong>
              </td>
              <td><%= r.guest.phone || '—' %></td>
              <td class="cell-ellipsis" title="<%= r.guest.email || '' %>"><%= r.guest.email || '—' %></td>
              <td class="cell-ellipsis" title="<%= r.guest.facebookHandle || '' %>"><%= r.guest.facebookHandle || '—' %></td>
              <td class="cell-ellipsis" title="<%= r.guest.instagramHandle || '' %>"><%= r.guest.instagramHandle || '—' %></td>
              <td><%= r.bookings.length %></td>
              <td><%= formatVnd(r.totalSpentVnd) %></td>
              <td><%= lastStay %></td>
              <td class="cell-ellipsis" title="<%= topItems %>"><%= topItems || '—' %></td>
              <td class="cell-ellipsis" title="<%= r.guest.notes || '' %>"><%= r.guest.notes || '—' %></td>
            </tr>
            <% if (r.bookings.length > 0) { %>
              <tr class="guest-bookings-row">
                <td></td>
                <td colspan="9">
                  <details>
                    <summary class="muted-small">Show <%= r.bookings.length %> booking<%= r.bookings.length === 1 ? '' : 's' %></summary>
                    <table style="margin-top:0.4rem;">
                      <thead><tr><th>Booking</th><th>Room</th><th>Check-in</th><th>Check-out</th><th>Status</th><th>Room charge</th><th>Minibar</th><th>Items used</th></tr></thead>
                      <tbody>
                        <% r.bookings.forEach(function(b){
                             var room = roomById(b.roomId);
                             var usages = (r.minibarByBooking.get(b.id) || []);
                             var itemSummary = usages.map(function(u){
                               var item = minibarItemById(u.minibarItemId);
                               return (item ? item.name : u.minibarItemId) + ' ×' + u.quantity;
                             }).join(', ');
                        %>
                          <tr>
                            <td><a href="/admin/bookings/<%= b.id %>"><%= b.bookingNumber %></a></td>
                            <td><%= room ? room.name : '—' %></td>
                            <td><%= formatDateTime(b.checkInAt) %></td>
                            <td><%= formatDateTime(b.checkOutAt) %></td>
                            <td><span class="badge"><%= b.status %></span></td>
                            <td><%= formatVnd(b.finalRoomChargeVnd) %></td>
                            <td><%= b.minibarChargesVnd ? formatVnd(b.minibarChargesVnd) : '—' %></td>
                            <td class="muted-small"><%= itemSummary || '—' %></td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </details>
                </td>
              </tr>
            <% } %>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
<%- include('../_footer') %>
