<%- include('../_header') %>
<%- include('_nav') %>
<h1>Notifications</h1>
<p><a href="/admin">← Dashboard</a></p>
<table>
  <thead><tr><th>When</th><th>Event</th><th>Booking</th><th>Cleaning job</th><th>Actor</th><th>Payload</th></tr></thead>
  <tbody>
    <% if (entries.length === 0) { %><tr><td colspan="6" class="muted">No notifications yet.</td></tr><% } %>
    <% entries.forEach(function(e){ var b = bookingById(e.bookingId); %>
      <tr>
        <td><%= formatDateTime(e.occurredAt) %></td>
        <td><code><%= e.event %></code></td>
        <td><% if (b) { %><a href="/admin/bookings/<%= b.id %>"><%= b.bookingNumber %></a><% } else { %>—<% } %></td>
        <td><%= e.cleaningJobId || '—' %></td>
        <td><%= e.actorUserId || '—' %></td>
        <td><% if (e.payload) { %><code><%= JSON.stringify(e.payload) %></code><% } %></td>
      </tr>
    <% }) %>
  </tbody>
</table>
<%- include('../_footer') %>
