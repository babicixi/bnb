<%- include('../_header') %>
<%- include('_nav') %>
<h1>Sales agents</h1>
<p class="muted-small">
  Commissions are calculated <strong>per booking</strong>. Percentage rules apply
  to the <em>net revenue after discount codes</em>; fixed rules pay a flat
  amount per booking. Fixed rule values and discount-code values are entered in
  <strong>thousands of VND</strong> (type <code>120</code> for ₫120,000).
</p>

<form method="get" action="/admin/agents" class="card" style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items:flex-end;">
  <div style="flex:0 0 auto;">
    <label>From week</label>
    <input type="date" name="from" value="<%= filters.from %>" />
  </div>
  <div style="flex:0 0 auto;">
    <label>To week</label>
    <input type="date" name="to" value="<%= filters.to %>" />
  </div>
  <div style="flex:0 0 auto;">
    <button type="submit">Apply range</button>
    <% if (!filters.isDefault) { %>
      <a href="/admin/agents" class="btn secondary" style="margin-left:0.4rem;">Reset to last 4 weeks</a>
    <% } %>
  </div>
  <div class="muted-small" style="flex:1 1 100%;">
    Defaults to the trailing 4 weeks. Filters every weekly table on this page (top dashboard + each agent's history).
  </div>
</form>

<div class="card">
  <h2>Weekly commission summary — all agents</h2>
  <% if (aggregateRows.length === 0) { %>
    <p class="muted">No commission activity yet.</p>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>Week of</th>
          <th>Bookings</th>
          <th>Net revenue</th>
          <th>Commissions earned</th>
          <th>Commissions paid</th>
          <th>Outstanding</th>
        </tr>
      </thead>
      <tbody>
        <% aggregateRows.forEach(function(r){
             var outstanding = Math.max(0, r.commissionVnd - r.paidAmountVnd);
        %>
          <tr>
            <td><strong><%= r.weekStartIso %></strong></td>
            <td><%= r.bookingCount %></td>
            <td><%= formatVnd(r.netRevenueVnd) %></td>
            <td><%= formatVnd(r.commissionVnd) %></td>
            <td><%= formatVnd(r.paidAmountVnd) %></td>
            <td>
              <% if (outstanding > 0) { %>
                <span class="badge bad"><%= formatVnd(outstanding) %></span>
              <% } else if (r.commissionVnd > 0) { %>
                <span class="badge good">paid</span>
              <% } else { %>
                —
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

<% agentRows.forEach(function(row){ %>
  <div class="card">
    <h2>
      <%= row.agent.fullName %>
      <span class="badge <%= row.agent.isActive ? 'good' : 'bad' %>"><%= row.agent.isActive ? 'active' : 'inactive' %></span>
      <a href="/admin/agents/<%= row.agent.id %>/report.csv" class="btn secondary" style="margin-left:0.5rem; font-size:0.85rem;">Download CSV report</a>
    </h2>
    <p class="muted-small">
      <%= row.agent.email %><% if (row.agent.phone) { %> · <%= row.agent.phone %><% } %>
      · lifetime: <%= row.lifetimeBookings %> bookings · <%= formatVnd(row.lifetimeNetRevenue) %> net
      · earned <%= formatVnd(row.lifetimeEarned) %> · paid <%= formatVnd(row.lifetimePaid) %>
    </p>

    <details style="margin-bottom: 0.75rem;">
      <summary><span class="badge">Edit profile</span></summary>
      <form method="post" action="/admin/agents/<%= row.agent.id %>/edit">
        <div class="grid cols-2">
          <div><label>Full name</label><input name="fullName" value="<%= row.agent.fullName %>" required /></div>
          <div><label>Email</label><input type="email" name="email" value="<%= row.agent.email %>" required /></div>
          <div><label>Phone</label><input name="phone" value="<%= row.agent.phone || '' %>" /></div>
          <div><label>New password (leave blank to keep current)</label><input type="text" name="password" autocomplete="new-password" /></div>
        </div>
        <p><button type="submit">Save profile</button></p>
      </form>
    </details>

    <div class="grid cols-2">
      <div>
        <h3>Commission rule</h3>
        <% if (row.rule) { %>
          <p>
            <strong>
              <% if (row.rule.commissionType === 'percentage') { %>
                <%= row.rule.value %>% of net revenue (after discount codes)
              <% } else { %>
                <%= formatVnd(row.rule.value) %> fixed per booking
              <% } %>
            </strong>
          </p>
        <% } else { %>
          <p class="muted">No active rule — agent will earn nothing until you set one.</p>
        <% } %>
        <form method="post" action="/admin/agents/<%= row.agent.id %>/rule">
          <div class="grid cols-2">
            <div>
              <label>Type</label>
              <select name="commissionType">
                <option value="percentage" <%= row.rule && row.rule.commissionType === 'percentage' ? 'selected' : '' %>>Percentage of net</option>
                <option value="fixed" <%= row.rule && row.rule.commissionType === 'fixed' ? 'selected' : '' %>>Fixed (₫'000)</option>
              </select>
            </div>
            <div>
              <label>Value <span class="muted-small">— <code>8</code> for 8%, <code>120</code> for ₫120,000</span></label>
              <%
                var displayValue = '';
                if (row.rule) {
                  displayValue = row.rule.commissionType === 'fixed'
                    ? row.rule.value / 1000
                    : row.rule.value;
                }
              %>
              <input type="number" name="commissionValue" step="any" min="0" value="<%= displayValue %>" required />
            </div>
          </div>
          <p>
            <button type="submit" class="secondary">Update rule</button>
          </p>
        </form>
        <p>
          <form method="post" action="/admin/agents/<%= row.agent.id %>/toggle" style="display:inline">
            <button type="submit" class="secondary"><%= row.agent.isActive ? 'Deactivate' : 'Activate' %> agent</button>
          </form>
          <form method="post" action="/admin/agents/<%= row.agent.id %>/delete" onsubmit="return confirm('Permanently delete this agent? Only allowed if they have no bookings or payments.')" style="display:inline; margin-left:0.5rem;">
            <button type="submit" class="danger">Permanently delete</button>
          </form>
        </p>
      </div>

      <div>
        <h3>Discount codes</h3>
        <% if (row.discounts.length === 0) { %><p class="muted-small">None assigned.</p><% } %>
        <% row.discounts.forEach(function(d){ var used = countDiscountUsage(d.id); %>
          <details style="margin-bottom:0.4rem;">
            <summary>
              <strong><%= d.name %></strong> —
              <%= d.discountType === 'percentage' ? d.value + '%' : formatVnd(d.value) %>
              · used <%= used %><% if (d.usageLimit) { %>/<%= d.usageLimit %><% } %>
              <span class="badge <%= d.isActive ? 'good' : 'bad' %>"><%= d.isActive ? 'active' : 'revoked' %></span>
            </summary>
            <form method="post" action="/admin/discounts/<%= d.id %>/edit" style="margin-top:0.4rem;">
              <div class="grid cols-2">
                <div><label>Name</label><input name="name" value="<%= d.name %>" required /></div>
                <div>
                  <label>Type</label>
                  <select name="discountType">
                    <option value="fixed" <%= d.discountType === 'fixed' ? 'selected' : '' %>>Fixed (₫'000)</option>
                    <option value="percentage" <%= d.discountType === 'percentage' ? 'selected' : '' %>>Percentage</option>
                  </select>
                </div>
                <div>
                  <label>Value <span class="muted-small">— <code>10</code> for 10% or <code>100</code> for ₫100,000</span></label>
                  <input type="number" name="value" min="0" step="any" value="<%= d.discountType === 'fixed' ? d.value / 1000 : d.value %>" required />
                </div>
                <div>
                  <label>Usage limit (blank = unlimited)</label>
                  <input type="number" name="usageLimit" min="1" value="<%= d.usageLimit || '' %>" />
                </div>
                <div>
                  <label>Valid from (optional)</label>
                  <input type="date" name="validFrom" value="<%= d.validFrom || '' %>" />
                </div>
                <div>
                  <label>Valid until (optional)</label>
                  <input type="date" name="validUntil" value="<%= d.validUntil || '' %>" />
                </div>
              </div>
              <p style="display:flex; gap:0.4rem; flex-wrap:wrap; align-items:center;">
                <button type="submit" class="secondary">Save changes</button>
              </p>
            </form>
            <p style="display:flex; gap:0.4rem; flex-wrap:wrap; align-items:center;">
              <form method="post" action="/admin/discounts/<%= d.id %>/toggle" style="display:inline">
                <button type="submit" class="secondary"><%= d.isActive ? 'Revoke' : 'Reactivate' %></button>
              </form>
              <% if (used === 0) { %>
                <form method="post" action="/admin/discounts/<%= d.id %>/delete" style="display:inline" onsubmit="return confirm('Permanently delete discount code &quot;<%= d.name %>&quot;? Only allowed because it has not been used on any booking.')">
                  <button type="submit" class="danger">Permanently delete</button>
                </form>
              <% } else { %>
                <span class="muted-small">Cannot delete — used on <%= used %> booking(s); revoke instead.</span>
              <% } %>
            </p>
          </details>
        <% }) %>
        <details>
          <summary>+ Assign a new discount code</summary>
          <form method="post" action="/admin/agents/<%= row.agent.id %>/discounts">
            <label>Name</label><input name="name" required placeholder="e.g. Repeat customer 100k" />
            <div class="grid cols-2">
              <div>
                <label>Type</label>
                <select name="discountType">
                  <option value="fixed">Fixed (₫'000)</option>
                  <option value="percentage">Percentage</option>
                </select>
              </div>
              <div>
                <label>Value <span class="muted-small">— <code>10</code> for 10% or <code>100</code> for ₫100,000</span></label>
                <input type="number" name="value" min="0" step="any" required />
              </div>
              <div>
                <label>Usage limit (blank = unlimited)</label>
                <input type="number" name="usageLimit" min="1" />
              </div>
              <div>
                <label>Valid until (optional)</label>
                <input type="date" name="validUntil" />
              </div>
            </div>
            <p><button type="submit">Create discount</button></p>
          </form>
        </details>
      </div>
    </div>

    <h3>Weekly commissions <span class="muted-small">(every week with activity, including historical)</span></h3>
    <% if (row.weeklyRows.length === 0) { %>
      <p class="muted">No commission activity yet.</p>
    <% } else { %>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Week of</th>
              <th>Bookings</th>
              <th>Net revenue</th>
              <th>Commissions</th>
              <th>Paid</th>
              <th>Screenshots</th>
              <th>Upload payment</th>
            </tr>
          </thead>
          <tbody>
            <% row.weeklyRows.forEach(function(w){
                 var outstanding = Math.max(0, w.commissionVnd - w.paidAmountVnd);
                 var formId = 'pay-' + row.agent.id + '-' + w.weekStartIso;
            %>
              <tr>
                <td>
                  <strong><%= w.weekStartIso %></strong>
                  <% if (outstanding > 0) { %><br><span class="badge bad"><%= formatVnd(outstanding) %> due</span>
                  <% } else if (w.commissionVnd > 0) { %><br><span class="badge good">paid</span><% } %>
                </td>
                <td><%= w.bookingCount %></td>
                <td><%= formatVnd(w.netRevenueVnd) %></td>
                <td><%= formatVnd(w.commissionVnd) %></td>
                <td><%= formatVnd(w.paidAmountVnd) %></td>
                <td>
                  <% if (w.payments.length === 0) { %>
                    <span class="muted-small">—</span>
                  <% } else { %>
                    <% w.payments.forEach(function(p){
                         var isVoid = p.status === 'void';
                    %>
                      <div style="display:flex; align-items:center; gap:0.4rem; margin-bottom:0.2rem; <%= isVoid ? 'opacity:0.5;' : '' %>">
                        <% if (p.screenshotUrl) { %>
                          <a href="<%= p.screenshotUrl %>" target="_blank" title="<%= formatVnd(p.amountVnd) %> · <%= formatDateTime(p.paidAt) %><% if (p.notes) { %> · <%= p.notes %><% } %>">
                            <img src="<%= p.screenshotUrl %>" alt="proof" style="height:36px; vertical-align:middle; border:1px solid var(--border); border-radius:3px;" />
                          </a>
                        <% } else { %>
                          <span class="muted-small" title="<%= formatDateTime(p.paidAt) %>"><%= formatVnd(p.amountVnd) %></span>
                        <% } %>
                        <span class="badge <%= isVoid ? 'bad' : 'good' %>"><%= isVoid ? 'voided' : 'paid' %></span>
                        <form method="post" action="/admin/agent-payments/<%= p.id %>/toggle" style="display:inline">
                          <button type="submit" class="secondary" style="padding:0.15rem 0.5rem; font-size:0.78rem;"><%= isVoid ? 'Mark paid' : 'Mark unpaid' %></button>
                        </form>
                        <form method="post" action="/admin/agent-payments/<%= p.id %>/delete" style="display:inline" onsubmit="return confirm('Delete this payment record? Cannot be undone.')">
                          <button type="submit" class="danger" style="padding:0.15rem 0.5rem; font-size:0.78rem;">×</button>
                        </form>
                      </div>
                    <% }) %>
                  <% } %>
                </td>
                <td>
                  <form method="post" action="/admin/agents/<%= row.agent.id %>/payments" enctype="multipart/form-data" id="<%= formId %>">
                    <input type="hidden" name="weekStartIso" value="<%= w.weekStartIso %>" />
                    <div style="display:flex; gap:0.4rem; align-items:center; flex-wrap:wrap;">
                      <label class="muted-small">₫'000</label>
                      <input type="number" name="amountK" min="0" step="1" value="<%= outstanding > 0 ? Math.round(outstanding / 1000) : '' %>" placeholder="amount" required style="max-width:90px" />
                      <input type="file" name="screenshot" accept="image/*" style="max-width:170px" />
                      <button type="submit" class="secondary">Upload</button>
                    </div>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
<% }) %>

<div class="card">
  <h2>Add a sales agent</h2>
  <form method="post" action="/admin/agents">
    <div class="grid cols-2">
      <div><label>Full name</label><input name="fullName" required /></div>
      <div><label>Email</label><input type="email" name="email" required /></div>
      <div><label>Phone (optional)</label><input name="phone" /></div>
      <div><label>Initial password (≥ 8 chars)</label><input type="text" name="password" required /></div>
      <div>
        <label>Commission type</label>
        <select name="commissionType">
          <option value="percentage">Percentage of net (after discount codes)</option>
          <option value="fixed">Fixed per booking (₫'000)</option>
        </select>
      </div>
      <div><label>Commission value <span class="muted-small">— <code>8</code> for 8% or <code>120</code> for ₫120,000</span></label><input type="number" name="commissionValue" min="0" step="any" required /></div>
    </div>
    <p><button type="submit">Create agent</button></p>
  </form>
</div>
<%- include('../_footer') %>
