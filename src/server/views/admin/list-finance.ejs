<%- include('../_header') %>
<%- include('_nav') %>
<h1><%= heading %></h1>
<table>
  <thead><tr><th>#</th><th>Guest</th><th>Room</th><th>Check-in</th><th>Amount</th><th></th></tr></thead>
  <tbody>
    <% if (bookings.length === 0) { %><tr><td colspan="6" class="muted">Nothing pending.</td></tr><% } %>
    <% bookings.forEach(function(b){ var g = guestForBooking(b); var r = roomForBooking(b); %>
      <tr>
        <td><a href="/admin/bookings/<%= b.id %>"><%= b.bookingNumber %></a></td>
        <td><%= g ? g.fullName : '—' %></td>
        <td><%= r ? r.name : '—' %></td>
        <td><%= formatDateTime(b.checkInAt) %></td>
        <td><%= formatVnd(b[column]) %></td>
        <td><a class="btn secondary" href="/admin/bookings/<%= b.id %>">Open</a></td>
      </tr>
    <% }) %>
  </tbody>
</table>
<%- include('../_footer') %>
