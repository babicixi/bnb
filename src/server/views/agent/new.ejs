<%- include('../_header') %>
<h1>Create booking on behalf of guest</h1>

<%
  const timeOptions = [];
  for (let h = 0; h < 24; h++) {
    for (let m = 0; m < 60; m += 30) {
      const v = String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0');
      timeOptions.push(v);
    }
  }
%>

<div class="card">
  <% if (error) { %><p class="error"><%= error %></p><% } %>
  <form method="post" action="/agent/new">
    <label>Room</label>
    <select name="roomId" id="roomSelect" required>
      <% rooms.forEach(function(r){ %>
        <option value="<%= r.id %>" data-hourly="<%= r.hourlyEnabled !== false ? '1' : '0' %>"><%= r.name %> (<%= formatVnd(r.baseDayRateVnd) %>/day)<%= r.hourlyEnabled === false ? ' · day-only' : '' %></option>
      <% }) %>
    </select>

    <p id="dayOnlyNotice" class="muted-small" style="display:none; background:#fff5e6; padding:0.5rem 0.75rem; border-radius:4px; border:1px solid #f0d4a8; margin-top:0.5rem;">
      This room is <strong>nightly only</strong> — times are locked to standard 14:00 / 11:00.
    </p>

    <div class="grid cols-2">
      <div>
        <label><%= t('booking.checkin_date') %></label>
        <input type="date" name="checkInDate" required />
      </div>
      <div>
        <label><%= t('booking.checkin_time') %></label>
        <select name="checkInTime" id="checkInTime" required>
          <% timeOptions.forEach(function(v){ %>
            <option value="<%= v %>" <%= v === '14:00' ? 'selected' : '' %>><%= v %></option>
          <% }) %>
        </select>
      </div>
      <div>
        <label><%= t('booking.checkout_date') %></label>
        <input type="date" name="checkOutDate" required />
      </div>
      <div>
        <label><%= t('booking.checkout_time') %></label>
        <select name="checkOutTime" id="checkOutTime" required>
          <% timeOptions.forEach(function(v){ %>
            <option value="<%= v %>" <%= v === '11:00' ? 'selected' : '' %>><%= v %></option>
          <% }) %>
        </select>
      </div>
    </div>

    <p class="muted-small">
      Booking type is detected automatically from the times.
      Day &amp; multi-day check-in must be at or after 14:00.
    </p>

    <script>
    (function(){
      var sel = document.getElementById('roomSelect');
      var notice = document.getElementById('dayOnlyNotice');
      var ci = document.getElementById('checkInTime');
      var co = document.getElementById('checkOutTime');
      function sync(){
        var opt = sel.options[sel.selectedIndex];
        var dayOnly = opt && opt.dataset.hourly === '0';
        notice.style.display = dayOnly ? '' : 'none';
        if (dayOnly) {
          ci.value = '14:00'; ci.disabled = true;
          co.value = '11:00'; co.disabled = true;
        } else {
          ci.disabled = false;
          co.disabled = false;
        }
      }
      sel.addEventListener('change', sync);
      sync();
      // Re-enable on submit so disabled selects still post their values
      var form = sel.closest('form');
      form.addEventListener('submit', function(){
        ci.disabled = false; co.disabled = false;
      });
    })();
    </script>

    <h3>Guest</h3>
    <label>Name</label><input name="guestName" required />
    <label>Phone</label><input name="guestPhone" required />
    <label><%= t('booking.email_required') %></label>
    <input type="email" name="guestEmail" required />
    <label><%= t('booking.facebook') %></label>
    <input type="text" name="guestFacebook" placeholder="facebook.com/handle or @handle" />
    <label><%= t('booking.instagram') %></label>
    <input type="text" name="guestInstagram" placeholder="@handle" />

    <label>Apply discount</label>
    <select name="discountId">
      <option value="">— none —</option>
      <% discounts.forEach(function(d){
           var label = d.name + ' (' + d.scope + ', ' + (d.discountType === 'percentage' ? d.value + '%' : formatVnd(d.value)) + ')';
           if (d.usageLimit !== undefined) {
             label += ' · used ' + (d.used || 0) + '/' + d.usageLimit;
           } else if (d.used) {
             label += ' · used ' + d.used;
           }
           if (d.exhausted) label += ' · LIMIT REACHED';
      %>
        <option value="<%= d.id %>" <%= d.exhausted ? 'disabled' : '' %>><%= label %></option>
      <% }) %>
    </select>

    <label>Notes</label>
    <textarea name="notes" rows="2"></textarea>
    <p><button type="submit"><%= t('booking.reserve') %></button></p>
  </form>
</div>
<%- include('../_footer') %>
