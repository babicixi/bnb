<%- include('_header', { bodyClass: 'landing' }) %>

<section class="hero">
  <div class="hero-inner">
    <h1><%= t('site.tagline') %></h1>
    <div class="hero-cta">
      <a href="#rooms" class="btn"><%= t('landing.browse_rooms') %></a>
      <a href="/lookup" class="btn secondary"><%= t('landing.find_booking') %></a>
    </div>
    <div class="hero-contacts">
      <a href="tel:0966699738" class="contact-pill">
        <span class="contact-label"><%= t('landing.reservations_label') %></span><br>
        <strong>0966.699.738</strong>
      </a>
      <a href="tel:0988643307" class="contact-pill">
        <span class="contact-label"><%= t('landing.cs_label') %></span><br>
        <strong>0988.643.307</strong>
      </a>
    </div>
  </div>
</section>

<section class="section" id="rooms">
  <h2><%= t('rooms.heading') %></h2>
  <p class="lede"><%= t('landing.intro') %></p>
  <% buildings.forEach(function(b) { %>
    <% if (b.rooms.length === 0) return; %>
    <h3 style="margin: 1.5rem 0 1rem; font-size: 1.15rem;">
      <%= b.name %> <span class="muted-small" style="font-weight: 400;">· <%= b.address %><% if (b.district) { %>, <%= b.district %><% } %>, <%= b.city %></span>
    </h3>
    <div class="room-grid">
      <% b.rooms.forEach(function(r) {
           var heroPhoto = r.photoUrls && r.photoUrls.length ? r.photoUrls[0] : null;
           var displayFeatures = (r.features || []).slice(0, 4);
           var fromHourly = r.hourlyEnabled === false ? null : r.baseHourlyRateVnd;
      %>
        <article class="room-card">
          <a class="media-link" href="/rooms/<%= r.id %>">
            <div class="media" style="<%= heroPhoto ? 'background-image: url(' + JSON.stringify(heroPhoto) + ');' : 'background: linear-gradient(135deg, #b03030 0%, #1a1a1a 100%);' %>">
              <span class="price-pill"><%= t('landing.from_per_night', formatVnd(r.baseDayRateVnd)) %></span>
            </div>
          </a>
          <div class="body">
            <h3><%= r.name %></h3>
            <p class="building-line">
              <%= t('landing.guests_up_to', r.maxGuests) %><% if (r.roomNumber) { %> · <%= t('landing.room_number', r.roomNumber) %><% } %>
            </p>
            <% if (displayFeatures.length) { %>
              <div class="feature-tags">
                <% displayFeatures.forEach(function(f){ %>
                  <span class="tag"><%= f %></span>
                <% }) %>
                <% if ((r.features || []).length > displayFeatures.length) { %>
                  <span class="tag"><%= t('landing.more_features', r.features.length - displayFeatures.length) %></span>
                <% } %>
              </div>
            <% } %>
            <% if (fromHourly) { %>
              <p class="muted-small" style="margin: 0 0 0.6rem;"><%= t('landing.or_per_hour', formatVnd(fromHourly)) %></p>
            <% } %>
            <a class="room-cta" href="/rooms/<%= r.id %>"><%= t('rooms.book_now') %></a>
          </div>
        </article>
      <% }) %>
    </div>
  <% }) %>
</section>

<%
  // Contact + social handles come from BRAND_* env vars via res.locals.brand.
  // Set BRAND_FB_URL / BRAND_IG_URL / BRAND_TT_URL / BRAND_PHONE_RESERVATIONS /
  // BRAND_PHONE_CS to surface them on the landing page.
  var fbUrl = brand.fbUrl;
  var igUrl = brand.igUrl;
  var ttUrl = brand.ttUrl;
  var fbHandle = brand.fbHandle;
  var igHandle = brand.igHandle;
  var ttHandle = brand.ttHandle;
  var phoneRes = brand.phoneReservations;
  var phoneCs  = brand.phoneCs;
  function telHref(p){ return p ? 'tel:' + p.replace(/[^0-9+]/g, '') : '#'; }
  var fbHref = fbUrl ? encodeURIComponent(fbUrl) : '';
%>

<% if (fbUrl || igUrl || ttUrl || phoneRes || phoneCs) { %>
<section class="section" style="text-align:center;">
  <h2><%= t('landing.talk_heading') %></h2>
  <p class="lede"><%= t('landing.talk_lede') %></p>
  <% if (fbUrl || igUrl || ttUrl) { %>
  <div class="social-row">
    <% if (fbUrl) { %>
    <a class="social-card facebook" href="<%= fbUrl %>" target="_blank" rel="noopener">
      <span class="social-icon" aria-hidden="true">f</span>
      <div>
        <strong><%= t('landing.fb_message') %></strong>
        <p><%= fbHandle %></p>
      </div>
    </a>
    <% } %>
    <% if (igUrl) { %>
    <a class="social-card instagram" href="<%= igUrl %>" target="_blank" rel="noopener">
      <span class="social-icon" aria-hidden="true">📷</span>
      <div>
        <strong><%= t('landing.ig_message') %></strong>
        <p><%= igHandle %></p>
      </div>
    </a>
    <% } %>
    <% if (ttUrl) { %>
    <a class="social-card tiktok" href="<%= ttUrl %>" target="_blank" rel="noopener">
      <span class="social-icon" aria-hidden="true">🎵</span>
      <div>
        <strong><%= t('landing.tt_watch') %></strong>
        <p><%= ttHandle %></p>
      </div>
    </a>
    <% } %>
  </div>
  <% } %>
  <% if (phoneRes || phoneCs) { %>
  <div class="social-row">
    <% if (phoneRes) { %>
    <a class="social-card phone-call reservations" href="<%= telHref(phoneRes) %>">
      <span class="social-icon" aria-hidden="true">☎</span>
      <div>
        <strong><%= t('landing.call_reservations') %></strong>
        <p><%= phoneRes %></p>
      </div>
    </a>
    <% } %>
    <% if (phoneCs) { %>
    <a class="social-card phone-call cs" href="<%= telHref(phoneCs) %>">
      <span class="social-icon" aria-hidden="true">☎</span>
      <div>
        <strong><%= t('landing.call_cs') %></strong>
        <p><%= phoneCs %></p>
      </div>
    </a>
    <% } %>
  </div>
  <% } %>
</section>
<% } %>

<% if (fbUrl) { %>
<section class="section" style="text-align:center;">
  <h2><%= t('landing.fb_heading') %></h2>
  <div class="fb-embed-wrap">
    <iframe
      src="https://www.facebook.com/plugins/page.php?href=<%= fbHref %>&tabs=timeline&width=500&height=600&small_header=true&adapt_container_width=true&hide_cover=false&show_facepile=true"
      class="fb-embed"
      scrolling="no" frameborder="0" allowfullscreen="true"
      allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
      loading="lazy"></iframe>
  </div>
</section>
<% } %>

<footer class="landing-footer">
  <p style="margin:0 0 0.5rem;"><%= t('footer.brand_line', new Date().getFullYear()) %></p>
  <p style="margin:0;">
    <% if (phoneRes) { %><a href="<%= telHref(phoneRes) %>" style="color:#fff;"><%= t('landing.reservations_label') %> <%= phoneRes %></a> · <% } %>
    <% if (phoneCs)  { %><a href="<%= telHref(phoneCs)  %>" style="color:#fff;"><%= t('landing.cs_label') %> <%= phoneCs  %></a> · <% } %>
    <a href="/lookup" style="color:#fff;"><%= t('footer.find_reservation') %></a>
  </p>
  <% if (fbUrl || igUrl || ttUrl) { %>
  <p style="margin:0.6rem 0 0;">
    <% if (fbUrl) { %><a href="<%= fbUrl %>" target="_blank" rel="noopener" style="color:#aaa; margin-right:0.75rem;">Facebook</a><% } %>
    <% if (igUrl) { %><a href="<%= igUrl %>" target="_blank" rel="noopener" style="color:#aaa; margin-right:0.75rem;">Instagram</a><% } %>
    <% if (ttUrl) { %><a href="<%= ttUrl %>" target="_blank" rel="noopener" style="color:#aaa;">TikTok</a><% } %>
  </p>
  <% } %>
</footer>

<%- include('_footer') %>
