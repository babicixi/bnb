<% var bodyClass = 'landing'; %>
<%- include('_header') %>

<section class="hero">
  <div class="hero-inner">
    <h1><%= t('site.tagline') %></h1>
    <p class="subtitle">Boutique serviced apartments in Hanoi — book by the hour, the day, or the week. Instant confirmation, transparent pricing, no hidden fees.</p>
    <div class="hero-cta">
      <a href="#rooms" class="btn">Browse rooms</a>
      <a href="/lookup" class="btn secondary">Find my booking</a>
    </div>
    <div class="hero-contacts">
      <a href="tel:0966699738" class="contact-pill">
        <span class="muted-small" style="opacity:0.85;">Reservations</span><br>
        <strong>0966.699.738</strong>
      </a>
      <a href="tel:0988643307" class="contact-pill">
        <span class="muted-small" style="opacity:0.85;">Customer service</span><br>
        <strong>0988.643.307</strong>
      </a>
    </div>
  </div>
</section>

<section class="section" id="rooms">
  <h2>Our rooms</h2>
  <p class="lede">Hand-picked spaces across our buildings — from cozy studios to family suites.</p>
  <% buildings.forEach(function(b) { %>
    <% if (b.rooms.length === 0) return; %>
    <h3 style="margin: 1.5rem 0 1rem; font-size: 1.15rem;">
      <%= b.name %> <span class="muted-small" style="font-weight: 400;">· <%= b.address %><% if (b.district) { %>, <%= b.district %><% } %>, <%= b.city %></span>
    </h3>
    <div class="room-grid">
      <% b.rooms.forEach(function(r) {
           var heroPhoto = r.photoUrls && r.photoUrls.length ? r.photoUrls[0] : null;
           var displayFeatures = (r.features || []).slice(0, 4);
           var fromHourly = r.hourlyEnabled === false ? null : r.baseHourlyRateVnd;
      %>
        <article class="room-card">
          <a class="media-link" href="/rooms/<%= r.id %>">
            <div class="media" style="<%= heroPhoto ? 'background-image: url(' + JSON.stringify(heroPhoto) + ');' : 'background: linear-gradient(135deg, #b03030 0%, #1a1a1a 100%);' %>">
              <span class="price-pill">from <%= formatVnd(r.baseDayRateVnd) %>/night</span>
            </div>
          </a>
          <div class="body">
            <h3><%= r.name %></h3>
            <p class="building-line">Up to <%= r.maxGuests %> guest<%= r.maxGuests === 1 ? '' : 's' %><% if (r.roomNumber) { %> · room <%= r.roomNumber %><% } %></p>
            <% if (displayFeatures.length) { %>
              <div class="feature-tags">
                <% displayFeatures.forEach(function(f){ %>
                  <span class="tag"><%= f %></span>
                <% }) %>
                <% if ((r.features || []).length > displayFeatures.length) { %>
                  <span class="tag">+<%= r.features.length - displayFeatures.length %> more</span>
                <% } %>
              </div>
            <% } %>
            <% if (fromHourly) { %>
              <p class="muted-small" style="margin: 0 0 0.6rem;">or <%= formatVnd(fromHourly) %>/hour</p>
            <% } %>
            <a class="room-cta" href="/rooms/<%= r.id %>"><%= t('rooms.book_now') %></a>
          </div>
        </article>
      <% }) %>
    </div>
  <% }) %>
</section>

<section class="section">
  <h2>Talk to us</h2>
  <p class="lede">Questions about rooms, dates, or special requests? Pick whichever channel you use most.</p>
  <div class="social-grid">
    <a class="social-card facebook" href="https://www.facebook.com/cixi.serviceapartments" target="_blank" rel="noopener">
      <span class="social-icon" aria-hidden="true">f</span>
      <div>
        <strong>Message us on Facebook</strong>
        <p>cixi.serviceapartments</p>
      </div>
    </a>
    <a class="social-card instagram" href="https://www.instagram.com/cixi.apartment" target="_blank" rel="noopener">
      <span class="social-icon" aria-hidden="true">📷</span>
      <div>
        <strong>DM us on Instagram</strong>
        <p>@cixi.apartment</p>
      </div>
    </a>
    <a class="social-card tiktok" href="https://www.tiktok.com/@apartmentcixi" target="_blank" rel="noopener">
      <span class="social-icon" aria-hidden="true">🎵</span>
      <div>
        <strong>Watch us on TikTok</strong>
        <p>@apartmentcixi</p>
      </div>
    </a>
    <a class="social-card phone" href="tel:0988643307">
      <span class="social-icon" aria-hidden="true">☎</span>
      <div>
        <strong>Call customer service</strong>
        <p>0988.643.307</p>
      </div>
    </a>
  </div>
</section>

<section class="section">
  <h2>Latest from our Facebook page</h2>
  <p class="lede">Recent photos, room updates, and guest moments — straight from facebook.com/cixi.serviceapartments.</p>
  <div class="fb-embed-wrap">
    <iframe
      src="https://www.facebook.com/plugins/page.php?href=https%3A%2F%2Fwww.facebook.com%2Fcixi.serviceapartments&tabs=timeline&width=500&height=600&small_header=true&adapt_container_width=true&hide_cover=false&show_facepile=true"
      width="500" height="600"
      style="border:none;overflow:hidden; max-width:100%; width:100%;"
      scrolling="no" frameborder="0" allowfullscreen="true"
      allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share"
      loading="lazy"></iframe>
  </div>
  <p class="muted-small" style="margin-top:0.5rem;">Doesn't load? <a href="https://www.facebook.com/cixi.serviceapartments" target="_blank" rel="noopener">Open our Facebook page in a new tab</a>.</p>
</section>

<footer class="landing-footer">
  <p style="margin:0 0 0.5rem;">© <%= new Date().getFullYear() %> Cixi Serviced Apartments · Hanoi</p>
  <p style="margin:0;">
    <a href="tel:0966699738" style="color:#fff;">Reservations 0966.699.738</a> ·
    <a href="tel:0988643307" style="color:#fff;">Customer service 0988.643.307</a> ·
    <a href="/lookup" style="color:#fff;">Find your reservation</a>
  </p>
  <p style="margin:0.6rem 0 0;">
    <a href="https://www.facebook.com/cixi.serviceapartments" target="_blank" rel="noopener" style="color:#aaa; margin-right:0.75rem;">Facebook</a>
    <a href="https://www.instagram.com/cixi.apartment" target="_blank" rel="noopener" style="color:#aaa; margin-right:0.75rem;">Instagram</a>
    <a href="https://www.tiktok.com/@apartmentcixi" target="_blank" rel="noopener" style="color:#aaa;">TikTok</a>
  </p>
</footer>

<%- include('_footer') %>
