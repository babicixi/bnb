<%- include('_header', { bodyClass: 'wide-page' }) %>

<div class="room-detail">

  <div class="room-detail-header">
    <h1 style="margin:0;"><%= room.name %></h1>
    <p class="muted" style="margin:0.3rem 0 0;">
      <%= building && building.name %><% if (room.roomNumber) { %> · room <%= room.roomNumber %><% } %>
      · up to <%= room.maxGuests %> guests
    </p>
  </div>

  <%
    const photos = room.photoUrls || [];
    const videos = room.videoUrls || [];
    const heroPhoto = photos[0];
    const sidePhotos = photos.slice(1, 5);
  %>

  <% if (videos.length) { %>
    <div class="video-row">
      <% videos.forEach(function(u){ %>
        <div class="video-tile"><%- videoEmbed(u) %></div>
      <% }) %>
    </div>
  <% } %>

  <% if (photos.length) { %>
    <div class="media-gallery <%= photos.length > 1 ? 'has-slideshow' : '' %>" id="room-gallery" data-photo-count="<%= photos.length %>">
      <button type="button" class="media-hero" data-photo-index="0" style="background-image: url('<%= heroPhoto %>');" aria-label="Open photo">
        <% if (photos.length > 1) { %>
          <span class="gallery-arrow gallery-prev" data-action="prev" aria-label="Previous">&#10094;</span>
          <span class="gallery-arrow gallery-next" data-action="next" aria-label="Next">&#10095;</span>
          <span class="gallery-counter"><span id="hero-counter">1</span> / <%= photos.length %></span>
        <% } %>
      </button>
      <% if (sidePhotos.length) { %>
        <div class="media-side">
          <% sidePhotos.forEach(function(u, i){ %>
            <button type="button" class="media-tile" data-photo-index="<%= i + 1 %>" style="background-image: url('<%= u %>');" aria-label="Open photo"></button>
          <% }) %>
          <% var fillSlots = 4 - sidePhotos.length; for (var j = 0; j < fillSlots; j++) { %>
            <div class="media-tile media-tile-empty"></div>
          <% } %>
        </div>
      <% } %>
    </div>
    <% if (photos.length > 5) { %>
      <p class="muted-small" style="margin:0.4rem 0 1rem;">
        <button type="button" class="link-button" id="show-all-photos">+<%= photos.length - 5 %> more — view all <%= photos.length %> photos</button>
      </p>
    <% } %>
  <% } %>

  <!-- Lightbox modal -->
  <% if (photos.length) { %>
    <div class="lightbox" id="lightbox" hidden>
      <button type="button" class="lightbox-close" data-action="close" aria-label="Close">&times;</button>
      <button type="button" class="lightbox-nav lightbox-prev" data-action="prev" aria-label="Previous">&#10094;</button>
      <button type="button" class="lightbox-nav lightbox-next" data-action="next" aria-label="Next">&#10095;</button>
      <img class="lightbox-img" id="lightbox-img" alt="Room photo" />
      <div class="lightbox-counter"><span id="lightbox-counter">1</span> / <%= photos.length %></div>
    </div>
  <% } %>

  <div class="room-detail-grid">
    <div class="room-detail-main">
      <div class="card">
        <p style="margin:0;">
          <strong style="font-size:1.25rem;"><%= formatVnd(room.baseDayRateVnd) %></strong>
          <span class="muted-small">/ night</span>
          <% if (room.hourlyEnabled !== false) { %>
            <span class="muted-small"> · or <%= formatVnd(room.baseHourlyRateVnd) %>/hour</span>
          <% } %>
        </p>
      </div>

      <% var desc = roomDescription(room); %>
      <% if (desc) { %>
        <div class="card">
          <h2><%= t('room.about') %></h2>
          <p><%= desc %></p>
        </div>
      <% } %>

      <% if (room.features && room.features.length) { %>
        <div class="card">
          <h2><%= t('room.features') %></h2>
          <div class="features-grid">
            <% room.features.forEach(function(f){ %>
              <div class="feature-pill">
                <span class="feature-pill-icon"><%= featureIcon(f) %></span>
                <span><%= featureLabel(f) %></span>
              </div>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>

    <aside class="room-detail-aside">
      <%
        const timeOptions = [];
        for (let h = 0; h < 24; h++) {
          for (let m = 0; m < 60; m += 30) {
            const v = String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0');
            timeOptions.push(v);
          }
        }
        const hourlyEnabled = room.hourlyEnabled !== false;
      %>
      <div class="card booking-form-card">
        <h2 style="margin-top:0;"><%= t('room.reserve') %></h2>
        <% if (!hourlyEnabled) { %>
          <p class="muted-small" style="background:#fff5e6; padding:0.5rem 0.75rem; border-radius:4px; border:1px solid #f0d4a8;">
            <%= t('room.nightly_only') %>
          </p>
        <% } %>
        <% if (error) { %><p class="error"><%= error %></p><% } %>
        <form method="post" action="/book/hold">
          <input type="hidden" name="roomId" value="<%= room.id %>" />

          <div class="grid cols-2 booking-times">
            <div>
              <label><%= t('booking.checkin_date') %></label>
              <input type="date" id="bf-checkInDate" name="checkInDate" required />
            </div>
            <% if (hourlyEnabled) { %>
              <div>
                <label><%= t('booking.checkin_time') %></label>
                <select id="bf-checkInTime" name="checkInTime" required>
                  <% timeOptions.forEach(function(v){ %>
                    <option value="<%= v %>" <%= v === '14:00' ? 'selected' : '' %>><%= v %></option>
                  <% }) %>
                </select>
              </div>
            <% } else { %>
              <div>
                <label class="muted-small"><%= t('room.standard_checkin') %></label>
                <p style="margin:0.55rem 0 0;"><strong>14:00</strong></p>
                <input type="hidden" id="bf-checkInTime" name="checkInTime" value="14:00" />
              </div>
            <% } %>
            <div>
              <label><%= t('booking.checkout_date') %></label>
              <input type="date" id="bf-checkOutDate" name="checkOutDate" required />
            </div>
            <% if (hourlyEnabled) { %>
              <div>
                <label><%= t('booking.checkout_time') %></label>
                <select id="bf-checkOutTime" name="checkOutTime" required>
                  <% timeOptions.forEach(function(v){ %>
                    <option value="<%= v %>" <%= v === '11:00' ? 'selected' : '' %>><%= v %></option>
                  <% }) %>
                </select>
              </div>
            <% } else { %>
              <div>
                <label class="muted-small"><%= t('room.standard_checkout') %></label>
                <p style="margin:0.55rem 0 0;"><strong>11:00</strong></p>
                <input type="hidden" id="bf-checkOutTime" name="checkOutTime" value="11:00" />
              </div>
            <% } %>
          </div>

          <div id="bf-availability" class="availability-banner empty">Pick check-in and check-out to see availability.</div>

          <p class="muted-small" style="margin-top:0.6rem;">
            <%= t('room.detect_rules') %><br>
            <strong><%= t('room.late_checkout') %>:</strong> <%= t('room.late_rules') %>
          </p>

          <h3 style="margin: 1.25rem 0 0.4rem;"><%= t('room.your_details') %></h3>
          <div class="grid cols-2 details-grid">
            <div>
              <label><%= t('booking.guest_name') %></label>
              <input type="text" name="guestName" required />
              <label><%= t('booking.phone') %></label>
              <input type="tel" name="guestPhone" required />
              <label><%= t('booking.email_required') %></label>
              <input type="email" name="guestEmail" required />
            </div>
            <div>
              <label><%= t('booking.facebook') %></label>
              <input type="text" name="guestFacebook" placeholder="facebook.com/yourname or @handle" />
              <label><%= t('booking.instagram') %></label>
              <input type="text" name="guestInstagram" placeholder="@yourhandle" />
              <label><%= t('booking.notes') %></label>
              <textarea name="notes" rows="3"></textarea>
            </div>
          </div>

          <p style="margin-top:1rem;"><button id="bf-submit" type="submit"><%= t('booking.reserve') %></button></p>
        </form>
      </div>
    </aside>
  </div>

</div>

<script>
(function(){
  var roomId = <%- JSON.stringify(room.id) %>;
  var ci = document.getElementById('bf-checkInDate');
  var co = document.getElementById('bf-checkOutDate');
  var cit = document.getElementById('bf-checkInTime');
  var cot = document.getElementById('bf-checkOutTime');
  var banner = document.getElementById('bf-availability');
  var submit = document.getElementById('bf-submit');
  function fmtVnd(n){ return new Intl.NumberFormat('vi-VN').format(n) + ' ₫'; }
  function compose(d, t){ return d && t ? d + 'T' + t : ''; }
  var debounce;
  var ctrl;
  function check(){
    var inAt = compose(ci.value, cit.value);
    var outAt = compose(co.value, cot.value);
    if (!inAt || !outAt) {
      banner.className = 'availability-banner empty';
      banner.textContent = <%- JSON.stringify(t('room.pick_dates')) %>;
      submit.disabled = false;
      return;
    }
    if (ctrl) ctrl.abort();
    ctrl = new AbortController();
    banner.className = 'availability-banner checking';
    banner.textContent = <%- JSON.stringify(t('room.checking')) %>;
    submit.disabled = true;
    fetch('/book/check?roomId=' + encodeURIComponent(roomId) +
          '&checkInAt=' + encodeURIComponent(inAt) +
          '&checkOutAt=' + encodeURIComponent(outAt), { signal: ctrl.signal })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (data.available) {
          banner.className = 'availability-banner ok';
          var typeLabel = data.bookingType === 'hourly' ? 'hourly' : (data.bookingType === 'multi_day' ? 'multi-day' : 'day');
          var extras = '';
          if (data.convertedToDayRate) {
            extras += ' (hourly past midnight → converted to day rate, check-out 11:00 next day)';
          }
          if (data.lateCheckoutFeeVnd > 0) {
            extras += ' · late check-out fee: <strong>' + fmtVnd(data.lateCheckoutFeeVnd) + '</strong>';
          }
          banner.innerHTML = '✓ Available · <strong>' + typeLabel + ' rate</strong> · total to collect: <strong>' + fmtVnd(data.amountToCollectVnd) + '</strong>' + extras;
          submit.disabled = false;
        } else {
          banner.className = 'availability-banner bad';
          banner.textContent = '✗ ' + (data.message || 'Not available.');
          submit.disabled = true;
        }
      })
      .catch(function(err){
        if (err && err.name === 'AbortError') return;
        banner.className = 'availability-banner bad';
        banner.textContent = 'Could not check availability — please try again.';
      });
  }
  function schedule(){ clearTimeout(debounce); debounce = setTimeout(check, 250); }
  [ci, cit, co, cot].forEach(function(el){
    if (!el) return;
    el.addEventListener('change', schedule);
    el.addEventListener('input', schedule);
  });
})();
</script>

<% if (photos.length) { %>
<script>
(function(){
  var photos = <%- JSON.stringify(photos) %>;
  var heroEl = document.querySelector('.media-hero');
  var heroCounter = document.getElementById('hero-counter');
  var lightbox = document.getElementById('lightbox');
  var lbImg = document.getElementById('lightbox-img');
  var lbCounter = document.getElementById('lightbox-counter');
  var current = 0;
  var heroIndex = 0;
  var rotateTimer = null;

  function setHero(idx){
    heroIndex = ((idx % photos.length) + photos.length) % photos.length;
    if (heroEl) heroEl.style.backgroundImage = "url('" + photos[heroIndex].replace(/'/g, "\\'") + "')";
    if (heroCounter) heroCounter.textContent = String(heroIndex + 1);
  }

  function startSlideshow(){
    if (photos.length <= 1) return;
    stopSlideshow();
    rotateTimer = setInterval(function(){ setHero(heroIndex + 1); }, 5000);
  }
  function stopSlideshow(){ if (rotateTimer) { clearInterval(rotateTimer); rotateTimer = null; } }

  function openLightbox(idx){
    if (!lightbox) return;
    current = idx;
    lbImg.src = photos[current];
    lbCounter.textContent = String(current + 1);
    lightbox.hidden = false;
    document.body.style.overflow = 'hidden';
    stopSlideshow();
  }
  function closeLightbox(){
    if (!lightbox) return;
    lightbox.hidden = true;
    document.body.style.overflow = '';
    startSlideshow();
  }
  function step(delta){
    current = ((current + delta) % photos.length + photos.length) % photos.length;
    lbImg.src = photos[current];
    lbCounter.textContent = String(current + 1);
  }

  // Hero & side tiles open the lightbox at their index
  document.querySelectorAll('[data-photo-index]').forEach(function(el){
    el.addEventListener('click', function(e){
      var act = e.target && e.target.dataset && e.target.dataset.action;
      if (act === 'prev') { e.preventDefault(); e.stopPropagation(); setHero(heroIndex - 1); return; }
      if (act === 'next') { e.preventDefault(); e.stopPropagation(); setHero(heroIndex + 1); return; }
      var idx = parseInt(el.dataset.photoIndex, 10) || 0;
      // hero opens at currently-visible index, tiles at their own
      openLightbox(el === heroEl ? heroIndex : idx);
    });
  });

  var showAll = document.getElementById('show-all-photos');
  if (showAll) showAll.addEventListener('click', function(){ openLightbox(0); });

  if (lightbox) {
    lightbox.addEventListener('click', function(e){
      var act = e.target && e.target.dataset && e.target.dataset.action;
      if (act === 'close' || e.target === lightbox) closeLightbox();
      else if (act === 'prev') step(-1);
      else if (act === 'next') step(1);
    });
    document.addEventListener('keydown', function(e){
      if (lightbox.hidden) return;
      if (e.key === 'Escape') closeLightbox();
      else if (e.key === 'ArrowLeft') step(-1);
      else if (e.key === 'ArrowRight') step(1);
    });
  }

  startSlideshow();
})();
</script>
<% } %>

<%- include('_footer') %>
