<%- include('_header') %>
<h1><%= room.name %></h1>
<p class="muted"><%= building && building.name %> · Room <%= room.roomNumber %> · up to <%= room.maxGuests %> guests</p>
<p>Day rate: <strong><%= formatVnd(room.baseDayRateVnd) %></strong> · Hourly: <%= formatVnd(room.baseHourlyRateVnd) %></p>

<% if (room.photoUrls && room.photoUrls.length) { %>
  <div style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:1rem;">
    <% room.photoUrls.forEach(function(u){ %>
      <a href="<%= u %>" target="_blank" class="image-thumb"><img src="<%= u %>" alt="<%= room.name %>" /></a>
    <% }) %>
  </div>
<% } %>

<% if (room.videoUrls && room.videoUrls.length) { %>
  <div style="display:flex; gap:1rem; flex-wrap:wrap; margin-bottom:1rem;">
    <% room.videoUrls.forEach(function(u){ %>
      <%- videoEmbed(u) %>
    <% }) %>
  </div>
<% } %>

<% if (room.description) { %><p><%= room.description %></p><% } %>

<% if (room.features && room.features.length) { %>
  <p><strong>Features:</strong>
    <% room.features.forEach(function(f, i){ %>
      <span class="badge" style="margin-right:0.25rem;"><%= f %></span>
    <% }) %>
  </p>
<% } %>

<%
  // Generate 30-minute time slots in 24-hour format.
  const timeOptions = [];
  for (let h = 0; h < 24; h++) {
    for (let m = 0; m < 60; m += 30) {
      const v = String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0');
      timeOptions.push(v);
    }
  }
%>

<%
  const hourlyEnabled = room.hourlyEnabled !== false;
%>
<div class="card">
  <h2>Book this room</h2>
  <% if (!hourlyEnabled) { %>
    <p class="muted-small" style="background:#fff5e6; padding:0.5rem 0.75rem; border-radius:4px; border:1px solid #f0d4a8;">
      This room is available for <strong>nightly stays only</strong>. Pick different dates for check-in and check-out.
    </p>
  <% } %>
  <% if (error) { %><p class="error"><%= error %></p><% } %>
  <form method="post" action="/book/hold">
    <input type="hidden" name="roomId" value="<%= room.id %>" />

    <div class="grid cols-2">
      <div>
        <label><%= t('booking.checkin_date') %></label>
        <input type="date" name="checkInDate" required />
      </div>
      <% if (hourlyEnabled) { %>
        <div>
          <label><%= t('booking.checkin_time') %></label>
          <select name="checkInTime" required>
            <% timeOptions.forEach(function(v){ %>
              <option value="<%= v %>" <%= v === '14:00' ? 'selected' : '' %>><%= v %></option>
            <% }) %>
          </select>
        </div>
      <% } else { %>
        <input type="hidden" name="checkInTime" value="14:00" />
      <% } %>
      <div>
        <label><%= t('booking.checkout_date') %></label>
        <input type="date" name="checkOutDate" required />
      </div>
      <% if (hourlyEnabled) { %>
        <div>
          <label><%= t('booking.checkout_time') %></label>
          <select name="checkOutTime" required>
            <% timeOptions.forEach(function(v){ %>
              <option value="<%= v %>" <%= v === '11:00' ? 'selected' : '' %>><%= v %></option>
            <% }) %>
          </select>
        </div>
      <% } else { %>
        <input type="hidden" name="checkOutTime" value="11:00" />
      <% } %>
    </div>

    <p class="muted-small">
      <% if (hourlyEnabled) { %>
        Booking type is detected automatically: same day → hourly · different days → day / multi-day.
        Day &amp; multi-day check-in must be at or after 14:00; check-out is normalised to 11:00 on the departure day.
        An hourly stay that crosses midnight becomes a day rate.
      <% } else { %>
        Standard check-in 14:00, check-out 11:00. Pick a check-out date later than check-in.
      <% } %>
    </p>

    <h3>Your details</h3>
    <label><%= t('booking.guest_name') %></label>
    <input type="text" name="guestName" required />
    <label><%= t('booking.phone') %></label>
    <input type="tel" name="guestPhone" required />
    <label><%= t('booking.email_required') %></label>
    <input type="email" name="guestEmail" required />
    <label><%= t('booking.facebook') %></label>
    <input type="text" name="guestFacebook" placeholder="facebook.com/yourname or @handle" />
    <label><%= t('booking.instagram') %></label>
    <input type="text" name="guestInstagram" placeholder="@yourhandle" />
    <label><%= t('booking.notes') %></label>
    <textarea name="notes" rows="2"></textarea>

    <p><button type="submit"><%= t('booking.reserve') %></button></p>
  </form>
</div>
<%- include('_footer') %>
